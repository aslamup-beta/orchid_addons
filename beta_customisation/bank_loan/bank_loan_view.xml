<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
	    <record model="ir.ui.view" id="view_bank_loan_tree_view">
	        <field name="name">od.beta.bank.loan.tree</field>
	        <field name="model">od.beta.bank.loan</field>
	        <field name="arch" type="xml">
	            <tree>
	            	<field name="name"/>
	            	<field name="req_type"/>
	            	
	            	<field name="job_id" />
	            	<field name="lab_no"/>
	            	<field name="state"/>
	            	
	            </tree>
	       </field>
	    </record>
	    
        <record id="view_bank_loan_form_view" model="ir.ui.view">
            <field name="name">od.beta.bank.loan.form</field>
            <field name="model">od.beta.bank.loan</field>
            <field name="arch" type="xml">
            <form string="Bank Loan Internal Procedure">
            <header>
				<button name="send_to_hr" type="object" class="oe_highlight" attrs="{'invisible':[('state', '!=', 'manager')]}" string="Manager Approval" />
				<button name="send_to_finance" type="object" class="oe_highlight" attrs="{'invisible':[('state', '!=', 'hr')]}" string="HR Approval" />
				<button name="od_confirm" type="object" class="oe_highlight" attrs="{'invisible':[('state', '!=', 'finance')]}" string="Finance Approval" groups="__export__.res_groups_186, orchid_beta.groups_beta_admin"/>
				<button name="reject_request" type="object" string="Reject" attrs="{'invisible':[('state', 'not in', ('manager','hr','finance'))]}"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,hr,finance,confirm" statusbar_colors='{"confirm":"blue"}'/>
            </header>
            <sheet>
            	<div class="oe_title">
	                 <label for="name" class="oe_edit_only"/>
	                 <h1>
	                     <field name="name" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                 </h1>
	                 <label for="work_email" class="oe_edit_only"/>
	                 <field name="work_email" widget="email" attrs="{'required': [('state','=','draft')],'readonly':[('state','!=','draft')]}"/>

                 </div>
            	
                <group> 
	               <group>
	               		<field name="job_id" attrs="{'required': [('state','=','draft')],'readonly':[('state','!=','draft')]}"/>
	                   <field name="department_id" attrs="{'required': [('state','=','draft')],'readonly':[('state','!=','draft')]}"/>
	                   <field name="manager_id" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                   <field name="branch_id" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
<!-- 	                   <field name="company_id" attrs="{'required': [('state','=','draft')],'readonly':[('state','in',('finance', 'confirm'))]}"/> -->
	                    <field name="req_type" attrs="{'required': [('state','=','draft')], 'readonly':[('state','=','confirm')]}"/>
	                    
	                    
	               </group>	 
	               <group>       
	               		<field name="govt_id" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>       
	               	   <field name="emp_id" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               	   <field name="passport_no" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                   <field name="lab_no" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                   
	                   <field name="nationality" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               		<field name="is_sal_trn_req" invisible="1"/> 
	                    <field name="is_loan_req" invisible="1"/> 
	               </group>
                </group>
                
                 <notebook>
                    <page string='Commitment'>
                    
                    <group>
				                <label colspan="4" width="500"
				                string="I, the employee hereby declare that the information provided is true and correct. I also understand that any willful
dishonesty may render for refusal of this application."/>
                	</group>
                    
                    <separator string="Feedbacks "/>
							<table style="width:100%" class="table table-striped">
								<thead>
									<th>Feedbacks </th>
<!-- 									<th>Manager Comments</th> -->
									<th>HR Comments</th>
									<th>Finance Comments</th>
								</thead>
								<tbody>
									<tr>
										<td>Form details</td>
<!-- 										<td> -->
<!-- 											<field name="m_form_cmd_id" attrs="{'readonly':[('state', '!=', 'manager')]}"/> -->
<!-- 										</td> -->
										<td>
											<field name="h_form_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_form_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									<tr>
										<td>Loan Bank details</td>
<!-- 										<td> -->
<!-- 											<field name="m_bank_cmd_id" attrs="{'readonly':[('state', '!=', 'manager')]}"/> -->
<!-- 										</td> -->
										<td>
											<field name="h_bank_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_bank_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									<tr>
										<td>Salary Transfer details</td>
<!-- 										<td> -->
<!-- 											<field name="m_salary_cmd_id" attrs="{'readonly':[('state', '!=', 'manager')]}"/> -->
<!-- 										</td> -->
										<td>
											<field name="h_salary_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_salary_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									<tr>
										<td>Is there any Loan with other Banks ?</td>
										<td>
											<field name="h_ongoing_loan_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_ongoing_loan_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									<tr attrs="{'invisible':[('h_ongoing_loan_cmd_id', '=', 2)]}">
										<td>Is there Clearance from other Bank ?</td>
										<td>
											<field name="h_clearance_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_clearance_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									<tr>
										<td>End of Service Transfer conditions</td>
<!-- 										<td> -->
<!-- 											<field name="m_eos_cmd_id" invisible="1"/> -->
<!-- 										</td> -->
										<td>
											<field name="h_eos_cmd_id" attrs="{'readonly':[('state', '!=', 'hr')]}"/>
										</td>
										<td>
											<field name="f_eos_cmd_id" attrs="{'readonly':[('state', '!=', 'finance')]}"/>
										</td>
									</tr>
									
									
									
								</tbody>
							</table>
							
							<div>
							</div>
							
					<group col="3">                 
	                      
	                       <group>
	                      	<field name="h_approved_by" readonly="1"/>
	                      	<field name="h_appr_date" readonly="1"/>
	                      </group>
	                      <group>
	                      	<field name="f_approved_by" readonly="1"/>
	                      	<field name="f_appr_date" readonly="1"/>
	                      </group>
	                      <group >
	                      	<field name="m_approved_by" readonly="1" invisible="1"/>
	                      	<field name="m_appr_date" readonly="1" invisible="1"/>
	                       </group>
                       </group>
                    
                    
             
                    </page>
                    
                    
                    
                    <page string='Salary Transfer Details' attrs="{'invisible': [('is_sal_trn_req','=', False)]}">
<!-- 	                    <label for="is_sal_trn_req" />     -->
<!-- 	                       <field name="is_sal_trn_req"/>     -->
	                    <group>
	                    	<group string='New Account Details' attrs="{'invisible': [('is_sal_trn_req','=', False)]}">
		                    	<field name="n_acc_name" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)], 'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="n_bank_name" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="n_account_number" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="n_swift_code" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="n_iban" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	</group>
	                    	
	                    	<group string='Old Account Details' attrs="{'invisible': [('is_sal_trn_req','=', False)]}">
		                    	<field name="o_acc_name" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="o_bank_name" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="o_account_number" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="o_swift_code" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
		                    	<field name="o_iban" attrs="{'required': [('is_sal_trn_req','!=', False)],'invisible': [('is_sal_trn_req','=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	</group>
	                    </group>
                    </page>
                    
                    <page string='Loan Bank Details' attrs="{'invisible': [('is_loan_req','=', False)]}">
                    <label for="date" />    
	                       <field name="date" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
                    <group>
                    	<group string='Loan Account Details'>
	                    	<field name="l_acc_name" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	<field name="l_bank_id" attrs="{'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	<field name="l_bank_name" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	<field name="l_bank_name_ar" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	
	                    	<field name="l_account_number" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	<field name="l_swift_code" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
	                    	<field name="l_iban" attrs="{'required': [('is_loan_req','!=', False)],'readonly':[('state','not in',('draft', 'manager'))]}"/>
                    	</group>
                    	<group></group>
                    </group>
                    
                    </page>
                    
                </notebook>
                

               </sheet>
            	<div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                </form>
            </field>
         </record>
         
        <record model="ir.actions.act_window" id="action_od_bank_loan_form">
        <field name="name">Bank Loan / Salary Transfer Internal Procedure</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">od.beta.bank.loan</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add a new bank loan approval from Beta
          </p>
        </field>
    </record>
    
     <menuitem id="od_menu_bank_loan_form" name="Bank Loan / Salary Transfer" action="action_od_bank_loan_form" parent="orchid_hrms.menu_od_hr_documents" sequence="100"/>
    
    
    </data>
</openerp>