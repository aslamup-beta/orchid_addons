<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
	    <record model="ir.ui.view" id="view_salary_profile_tree_view">
	        <field name="name">hr.salary.profile.tree</field>
	        <field name="model">hr.salary.profile</field>
	        <field name="arch" type="xml">
	            <tree>
	            	<field name="name"/>
	            	<field name="job_id" />
	            	<field name="nationality"/>
	            	<field name="state"/>
	            	
	            </tree>
	       </field>
	    </record>
	    
        <record id="view_salary_profile_form_view" model="ir.ui.view">
            <field name="name">hr.salary.profile.form</field>
            <field name="model">hr.salary.profile</field>
            <field name="arch" type="xml">
            <form string="Employee Salary Profile">
            <header>
				<button name="validate" type="object" class="oe_highlight" attrs="{'invisible':[('state', '!=', 'draft')]}" string="Validate"/>
				<button name="cancel" type="object" string="Cancel" attrs="{'invisible':[('state', '=', 'cancel')]}" />
                <field name="state" widget="statusbar" statusbar_visible="draft,valid,cancel" statusbar_colors='{"valid":"blue"}'/>
            </header>
            <sheet>
            	<div class="oe_title">
	                 <label for="name" class="oe_edit_only"/>
	                 <h1>
	                     <field name="name" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                 </h1>
                 </div>
            	
                <group> 
	               <group>
	               	    <field name="job_id" attrs="{'required': [('state','=','draft')],'readonly':[('state','!=','draft')]}"/>
	                    <field name="basic_salary" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                    <field name="allowance" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
					   <field name="housing_allowance" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
					   <field name="transport_allowance" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                    <field name="total_salary" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	                    <field name="company_id" invisible="1" />
	                    <field name="name_of_bank" string="Bank Name(Arabic)" invisible="1" />
	                    <field name="ref_to" />
	                    <field name="ref_to_ar" attrs="{'invisible': [('company_id','!=', 6)]}"/>
	                    <field name="print_type" attrs="{'invisible': [('company_id','!=', 6)]}"/> 
	                    
	                    
	                    
	               </group>	 
	               <group>
	               		<field name="date" />
	               	    <field name="nationality" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               	    <field name="join_date" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               	    <field name="staff_id" attrs="{'required': [('state','=','draft')],'readonly':[('state','!=','draft')]}"/>
	               	    <field name="govt_id" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               	    <field name="passport_no" attrs="{'required': [('state','=','draft')], 'readonly':[('state','!=','draft')]}"/>
	               		
	               		
	               </group>
	               
                </group>
                <field name="phrase_en" attrs="{'invisible': [('company_id','!=', 6)]}" />
				<field name="phrase" attrs="{'invisible': [('company_id','!=', 6)]}" />
               </sheet>
            	<div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                </form>
            </field>
         </record>
         
        <record model="ir.actions.act_window" id="action_od_salary_profile_form">
        <field name="name">Create Salary Certificate</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.salary.profile</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            You can generate Salary Certificates from here
          </p>
        </field>
    </record>
    
<!--      <menuitem id="od_menu_salary_profile_form" name="Salary Profile" action="action_od_salary_profile_form" parent="orchid_hrms.menu_od_hr_documents" sequence="101"/> -->
     <menuitem id="od_menu_emp_salary_profile_form" name="Salary Certificates" action="action_od_salary_profile_form" parent="hr.menu_hr_main" groups="__export__.res_groups_246,__export__.res_groups_245,__export__.res_groups_200" sequence="10"/>
    
    
    </data>
</openerp>