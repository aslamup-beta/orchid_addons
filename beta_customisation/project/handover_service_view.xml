<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
	    <record model="ir.ui.view" id="view_service_handover_tree_view">
	        <field name="name">handover.service.tree</field>
	        <field name="model">handover.service</field>
	        <field name="arch" type="xml">
	            <tree>
	            	<field name="name"/>
	            	<field name="customer_id"/>
	            	<field name="cost_sheet_id"/>
	            	<field name="so_val"/>
	            	<field name="po_no"/>
	            	<field name="po_date"/>
	            	<field name="od_sam" />
	            	<field name="od_proj_manager"/>
	            	<field name="state"/>
	            </tree>
	       </field>
	    </record>
	    
        <record id="service_handover_form_view" model="ir.ui.view">
            <field name="name">handover.service.form</field>
            <field name="model">handover.service</field>
            <field name="arch" type="xml">
            <form string="Service Handover Form">
            <header>
				<button name="approve_ho" type="object"  string="Approve" class="oe_highlight" attrs="{'invisible':[('state','!=','handover')]}" groups="orchid_beta.group_od_sd_engineer,orchid_beta.group_od_sd_mananger,__export__.res_groups_171,__export__.res_groups_196,orchid_beta.groups_beta_admin"/>
				<button name="reject_ho_wizard" type="object" string="Reject" attrs="{'invisible':[('state','!=','handover')]}" groups="orchid_beta.group_od_sd_engineer,orchid_beta.group_od_sd_mananger,__export__.res_groups_171,__export__.res_groups_196,orchid_beta.groups_beta_admin"/>
                <field name="state" widget="statusbar" />
            </header>
            	<sheet>
	    			<div class="oe_title">
	                    <label for="name" class="oe_edit_only"/>
	                    <h1>
	                        <field name="name"/>
	                    </h1>
	                </div>
                <group>
	               <group>
	               
	               		<field name="cost_sheet_id" required="1" domain="[('state','=','done'), ('status','=','active')]"/>
		               <field name="od_sam" />
		               <field name="od_proj_manager" />
		               <field name="contract_no" required="1"/>
		               <field name="contract_date" required="1"/>
		                
	               </group>	
	               <group>
	               		<field name="po_no"/>
	               		<field name="po_date"/>
	                   	<field name="so_approval_date" required="1"/>
	                   	<field name="proj_so" required="1" domain="[('od_cost_sheet_id','=',cost_sheet_id)]"/>
	                   	<field name="so_val" required="1"/>
	        		</group>              
                </group>
                <group>
                
                <field name="company_id" invisible="1"/>
	                <field name="customer_id" domain="[('is_company','=',True)]"/>
		            <field name="od_contact_ids" domain="[('parent_id','=',customer_id)]"/>
	            </group>
	                <notebook>
	                  
	                  
	                  <page string="Project Overview Details">
	                  <group>
	               		<field name="final_doc_folder" required="1" domain="[('od_cost_sheet_id','=',cost_sheet_id)]"/>
			       		<field name="project_doc" />
	                  </group>
	                  <group>
		                  <group>
			                  <field name="backup_copy" />
	                 		<field name="sla_inc" />
			                  
			                  </group>
			                  <group>
			                  
<!-- 			                    <field name="amc_so" /> -->
			                    <field name="is_proj_closed" />
			                    <field name="vendor_warranty" />
		                  </group>
	                  	  
	                  
	                   		
	                  </group> 
	                  
	                  		<group>
				                
                	                  			<field name="tac_rma_case" widget="radio" />
                <label string="If yes, then provide the following details.." colspan="4" width="500"/>
                			</group>
	                  	<div>
	                   	 
	                   	 <field name='rma_case_id'>
                            <tree editable='bottom'>
                                <field name="manufacture"/>
                                <field name="equipment"/>
                                <field name="location"/>
                                <field name="case_no"/>
                                <field name="case_status"/>
                                <field name="case_date"/>
                                <field name="beta_it_engineer"/>
                                <field name="vendor_tac_contact"/>
                            </tree>
                        </field>
	                    
	                	</div>
	                	<group string="Remarks"><field name="comments" placeholder="Additional Information to be highlighted on the Handover"/></group>
	                	<group string="Payment Details"><field name="payment_details" placeholder="Payment Details, Invoicing Instructions and documents required during the submission of invoice."/></group>
                       	<group string="Reject Reason" attrs="{'invisible':[('state','!=','reject')]}"><field name="rej_reasn" readonly="1" attrs="{'invisible':[('state','!=','reject')]}"/></group>
                       
                       
                       
                       
						</page>
							
						<page string="Preventive Maintanance" attrs="{'invisible':[('state','=','draft')]}">
							<group string ="Preventive Maintanance Line (To be filled by SD)">
                       			<field name="preventive_maintance_line" nolabel="1">
									<tree editable='bottom'>
										<field name="project_id" required="1"/>
										<field name="name" required="1"/>
										<field name="date" required="1"/>
									</tree>
								</field>
							</group>
						</page>
						<page string="Log Date History">
						<group string="Log Date History">	
                       <field name="date_log_history_line" nolabel="1">
								<tree>
									<field name="name"/>
									<field name="user_id"/>
									<field name="date"/>
								</tree>
							</field>
							</group>
	                  
	                  </page>
	                </notebook>
	                
               </sheet>
            	<div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                </form>
            </field>
         </record>
         
	     <record model="ir.actions.act_window" id="action_od_beta_service_handover_form">
	        <field name="name">Handover to Service Desk</field>
	        <field name="type">ir.actions.act_window</field>
	        <field name="res_model">handover.service</field>
	        <field name="view_type">form</field>
	        <field name="view_mode">tree,form</field>
	         <field name="help" type="html">
	          <p class="oe_view_nocontent_create">
	            Click to Create a Service Handover.
	          </p>
	        </field>
	    </record>
	    
	    <record id="wiz_request_handover_reject_form" model="ir.ui.view">
            <field name="name">Handover Rejected</field>
            <field name="model">wiz.handover.reject</field>
            <field name="arch" type="xml">
                <form string="Assign" >
                 
                     
                     <group string="Please fill the below fields before rejecting..">
						<field name="rej_reasn" required="1"/>
                      </group>
                    
                <footer>
                  <button name="send_lost_req" string="Reject" type="object" class="oe_highlight"/>
                    or
                  <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
                </form>
            </field>
        </record>
    
     <menuitem id="od_menu_beta_handover_to_service" name="Handover to Service Desk" action="action_od_beta_service_handover_form" parent="project.menu_project_management" sequence="103"/>
    	
    
    </data>
</openerp>