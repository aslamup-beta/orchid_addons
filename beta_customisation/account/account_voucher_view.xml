<?xml version="1.0"?>
<openerp>

	<data>	
		<record model="ir.ui.view" id="view_analytic_dist_voucher_form_inherit">
            <field name="name">account.voucher.form.inherit1</field>
            <field name="model">account.voucher</field>
            <field name="inherit_id" ref="account_voucher.view_vendor_receipt_form"/>
            <field name="arch" type="xml">
            <xpath expr="//page[@string='Journal Items']" position="after">
	          
               
               
               <page string="Analytic Distribution" invisible="1">
                            <field name="od_analytic_line">
                                <tree string="Analytic Distribution" editable="bottom">
                                    <field name="analytic_id" context="{'analytic_all':1}"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>
                        </xpath>
	        </field>
	     </record>
	     
	     <record model="ir.ui.view" id="view_analytic_dist_vendor_payment_form_inherit">
            <field name="name">account.voucher.payment.form.inherit1</field>
            <field name="model">account.voucher</field>
            <field name="inherit_id" ref="account_voucher.view_vendor_payment_form"/>
            <field name="arch" type="xml">
            <xpath expr="//page[@string='Journal Items']" position="after">
	          
               <page string="Bank Charge">
               <group>
               <field name="is_bc" />
            
                  <group attrs="{'invisible':[('is_bc','=',False)]}">
                     <field name="bc_amount" attrs="{'required':[('is_bc','=',True)]}"/>
                     <field name="bc_narration" attrs="{'required':[('is_bc','=',True)]}" />
                     <field name="bc_move_id" readonly="1" />
                  </group>
                  <group attrs="{'invisible':[('is_bc','=',False)]}">
                    <field name="bc_journal" attrs="{'required':[('is_bc','=',True)]}" />
                    <field name="bc_debit_acc_id" attrs="{'required':[('is_bc','=',True)]}" domain="[('type','&lt;&gt;','view'),('type','&lt;&gt;','consolidation')]"/>
                    <field name="bc_credit_acc_id" attrs="{'required':[('is_bc','=',True)]}" domain="[('type','&lt;&gt;','view'),('type','&lt;&gt;','consolidation')]" />
                  </group>
               
               </group>
               </page>
               <page string="Analytic Distribution" invisible="1">
                            <field name="od_analytic_line">
                                <tree string="Analytic Distribution" editable="bottom">
                                    <field name="analytic_id" context="{'analytic_all':1}"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>
                        </xpath>
	        </field>
	     </record>
	           
</data>
</openerp>