        <record model="ir.ui.view" id="change_invplan_tree_view">
            <field name="name">change.invplan.tree</field>
            <field name="model">change.invplan</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="tree_string">
                    <field name="name" />
                    <field name="user_id" />

                    <field name="date" />
                    <field name="pmo_user_id" />


                    <field name="state" />
                </tree>
            </field>
        </record>

