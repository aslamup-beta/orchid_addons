<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record id="view_project_project_form_change_inherit" model="ir.ui.view">
            <field name="name">project.project.form.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project" />
            <field name="arch" type="xml">
                <xpath expr="/form/sheet/div[@name='buttons']" position="inside">
                    <button class="oe_inline oe_stat_button" name="od_change_proc" type="object" icon="fa-book">
                        <div> Procurment<br/>
                         Change</div>
                    </button>

                    <button class="oe_inline oe_stat_button" name="od_change_inv" type="object" icon="fa-book">
                        <div> Inv Change</div>
                    </button>
                    <button class="oe_inline oe_stat_button" name="od_change_redist" type="object" icon="fa-book">
                        <div>Change Revenue<br/>
                         Structure</div>
                    </button>


                </xpath>
            </field>
        </record>


    </data>
</openerp>