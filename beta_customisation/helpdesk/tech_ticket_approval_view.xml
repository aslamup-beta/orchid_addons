<?xml version="1.0" encoding="UTF-8"?>
<openerp>
	<data>

		<record model="ir.ui.view" id="ticket_approval_form">
		<field name="name">ticket approval form view</field>
		<field name="model">od.tech.ticket.approval</field>
		<field name="arch" type="xml">
		<form string="Service Team Activities Approvals" create="false" edit="false">
 			<header>
 			         <button name="btn_done" class="oe_highlight" states="draft" string="Mark as Completed" type="object" />
 			         <button name="btn_cancel" states="draft" string="Cancel" type="object" />
                    <field name="state" widget="statusbar" nolabel="1" />
                </header>
 			<sheet>
 			
			<group>
			     <group>
			       <field name="name" readonly="1"/>
			       <field name="user_id" readonly="1"/>
			        <field name="company_id" invisible="1"/>
			     </group>
			     <group>
			         <field name="date" readonly="1"/>
			         <field name="partner_id" readonly="1"/>
			     </group>
			      
					
			</group>
			<notebook>
			  <page string="Activities Assigned">
			    <field name="ticket_line_ids" readonly="1">
			       <tree editable="bottom">
			         <field name="approval_form_id" invisible="1"/>
			         <field name="assigned_id" />
			         <field name="date_start" />
			         <field name="date_end" />
			         <field name="duration" />
			          <field name="status" />
			          <field name="ticket_id"/>
			          <button name="btn_open_activity" type="object" icon="STOCK_FIND" string="Open" />
			          <button name="btn_confirm"  string="Approve" type="object" attrs="{'invisible':[('status','!=','draft')]}" />
			          <button name="btn_cancel"  string="Cancel" type="object" attrs="{'invisible':[('status','!=','draft')]}" />
			       </tree>
			    </field>
			  </page>
			</notebook>
			</sheet>
		</form>
		</field>
		</record>

		<record model="ir.ui.view" id="ticket_approval_tree">
		<field name="name">Activities approval tree view</field>
		<field name="model">od.tech.ticket.approval</field>
		<field name="arch" type="xml">
			<tree string="Activities Approval ">
				<field name="date" />
				<field name="name" />
		        <field name="partner_id" />
		        <field name="user_id" />
		        <field name="state" />
		        
			</tree>
		</field>
		</record>

		<record model="ir.ui.view" id="ticket_approval_search">
		<field name="name">ticket approval search view</field>
		<field name="model">od.tech.ticket.approval</field>
		<field name="arch" type="xml">
			<search>
				<field name="name" />
		        <field name="partner_id" />
		        <field name="user_id" />
		        <group expand="0" string="Group By" colspan="16">
                        <filter string="Project Manager" context="{'group_by':'user_id'}"/>
                         <filter name= "state" string="State" context="{'group_by':'state'}"/>
					</group>
			</search>
		</field>
		</record>


		<record model="ir.actions.act_window" id="action_ticket_approval">
		<field name="name">Activity Approval Form</field>
		<field name="res_model">od.tech.ticket.approval</field>
		<field name="view_mode">tree,form</field>
		</record>

		<menuitem 
	  		id="menu_ticket_approval" 
	  		name="Activity Approval Form"
	  		parent="orchid_beta_project.od_menu_technical_sub"
            action="action_ticket_approval" sequence="100"/>

	</data>
</openerp>
