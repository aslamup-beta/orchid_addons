        <record id="view_od_stock_aging_report_form_xls" model="ir.ui.view">
            <field name="name">Stock Aging Report</field>
            <field name="model">od.stock.aging.report.wizard.xls</field>
            <field name="arch" type="xml">
                <form string="Stock Aging Report">
                    <group>
                    <group>
                        <field name="product_id"/>
                        <field name="location_id" required="1"/>
                        <field name="period_length"/>
                        
                    </group>


                    <group>
                        <field name="categ_id"/>
                        <field name="age" invisible="1"/>
                        <field name="stock_list"/>
                        <field name="compare" groups="orchid_beta.groups_beta_admin"/>
                       <!--  <field name="detail"/> -->
                    </group>
                   </group>
                    <footer>
                        <button name="export_rpt" string="Export" type="object" default_focus="1" class="oe_highlight"/> 
		                 or
                        <button name="print_directly" string="Print" type="object" class="oe_highlight"/>
                       or
                        <button string="Cancel" special="cancel" />
 
 				 
 				 </footer>
            
               </form>
            </field>
        </record>
        
