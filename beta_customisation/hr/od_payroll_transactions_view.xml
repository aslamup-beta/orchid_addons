<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_employee_payroll_transactions_tree" model="ir.ui.view">
            <field name="name">od.employee.payroll.transactions.line.tree</field>
            <field name="model">od.payroll.transactions.line</field>
            <field name="arch" type="xml">
				<tree string="Employee Payroll Transactions" editable="top">
					<field name="employee_id" required="1"/>
					<field name="product_id"/>
					<field name="transaction_note_id"/>
					<field name="period_id"/>
					<field name="allowance"/>
					<field name="deduction"/>
				</tree>
			</field>
        </record>
        
        <record model="ir.ui.view" id="view_employee_payroll_transactions_search">
			<field name="name">od.payroll.transactions.line.search</field>
			<field name="model">od.payroll.transactions.line</field>
			<field name="arch" type="xml">
				<search>
                    <group expand="0" string="Group By">
                        <filter string="Employee" context="{'group_by':'employee_id'}"/>
                        <filter string="Period" context="{'group_by':'period_id'}"/>
                    </group>
				</search>
			</field>
		</record>

        <record id="action_employee_payroll_transactions" model="ir.actions.act_window">
            <field name="name">Employee Payroll Transactions</field>
            <field name="res_model">od.payroll.transactions.line</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree</field>
            <field name="search_view_id" ref="view_employee_payroll_transactions_search" />
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
              </p>
            </field>
        </record>
        
<menuitem id="action_employee_payroll_transactions_menu" name="Employee Transactions" action="action_employee_payroll_transactions" parent="hr_expense.next_id_49" sequence="1"/>

    </data>
</openerp>