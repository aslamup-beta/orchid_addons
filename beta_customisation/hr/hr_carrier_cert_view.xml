<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
    <record model="ir.ui.view" id="od_hr_cert_lines_tre_views">
        <field name="name">od.hr.employee.certificate.line</field>
        <field name="model">od.hr.employee.certificate.line</field>
        <field name="arch" type="xml">
            <tree editable="top">
                   <field name="document_type_id"/>
                   <field name="document_referance" string="Name"/>
                   <field name="employee_id" invisible="1"/>
                   <field name="attach_file" filename="attach_fname"/>
                   <field name="attach_fname" invisible="1"/>
                   <field name="issue_date" />
                   <field name="expiry_date" required="1"/>
            </tree>
       </field>
    </record>

<record model="ir.actions.act_window" id="action_od_hr_cert_lines_tree_view">
        <field name="name">Certificate Attach</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">od.hr.employee.certificate.line</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add new Document Attach. 
          </p>
        </field>
    </record>
    
     <record model="ir.ui.view" id="od_hr_appreciation_lines_tre_views">
        <field name="name">od.hr.employee.appreciation.line</field>
        <field name="model">od.hr.employee.appreciation.line</field>
        <field name="arch" type="xml">
            <tree editable="top">
                   <field name="partner_id" required="1"/>
                   <field name="date" required="1"/>
                   <field name="document_referance" string="Appreciation Ref" required="0" invisible="1"/>
                   <field name="employee_id" invisible="1"/>
                   <field name="attach_file" filename="attach_fname" required="1"/>
                   <field name="attach_fname" invisible="1"/>
                   
            </tree>
       </field>
    </record>

<record model="ir.actions.act_window" id="action_od_hr_appreciation_lines_tree_view">
        <field name="name">Attach Appreciation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">od.hr.employee.appreciation.line</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Appreciations where employees can add and attach appreciation letters they get from customers as pdf attachment. 
          </p>
        </field>
    </record>
    
 </data>
</openerp>
