<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
      <record id="view_sale_achieve_report_tree" model="ir.ui.view">
            <field name="name">sales.achieve.report.view</field>
            <field name="model">sales.achieve.report</field>
            <field name="priority">27</field>
            <field name="arch" type="xml">
                <tree string="Sales Achievement Report" create="false">
                     <field name="month_start"/>
                     <field name="month_end"/>
                     <field name="sam_id"/>
                     <field name="annual_target" invisible="1"/>
                     <field name="mnthly_target" sum="Total"/>
                     <field name="accumulated_target"/>
                     
                     <field name="commit_kpi" sum="Total"/>
                     <field name="commit_perc"/>
                     <field name="achieved_kpi" sum="Total"/>
                     <field name="achieved_perc"/>
                     <field name="accumulated_achiev"/>
                     <field name="deficit"/>
                     <field name="amt_to_target"/>
                </tree>
            </field>
        </record>

    <record id="view_sales_achievement_report_search" model="ir.ui.view">
        <field name="name">sales.achieve.report.view</field>
        <field name="model">sales.achieve.report</field>
        <field name="arch" type="xml">
            <search string="Sales Achievement">

                <field name="sam_id" string="SAM"/>
                <field name="company_id" string="Company"/>
                    <group string="Group By...">
                     <filter string="Employee" icon="terp-personal" name="od_employee" context="{'group_by':'sam_id'}"/>
                     <filter string="Audit Month" name="od_month" context="{'group_by':'month_start:month'}"/>
                    </group>
            </search>
        </field>
    </record>

    <record id="action_sales_achievement" model="ir.actions.act_window">
        <field name="name">Sales Achievement Report</field>
        <field name="res_model">sales.achieve.report</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_sales_achievement_report_search"/>
        <field name="view_id" ref="view_sale_achieve_report_tree"/>
        <field name="context">{'search_default_od_employee': 1,'search_default_od_month': 1}</field>
        <field name="help">Sales Achievement Report</field>
    </record>

<menuitem parent="base.next_id_64" action="action_sales_achievement" id="menu_beta_sales_achievement" sequence="5"/>

    </data>
</openerp>
