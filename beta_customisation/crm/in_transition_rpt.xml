<?xml version="1.0"?>
<openerp>
    <data>
    
    
    <record model="ir.ui.view" id="od_cost_sheet_transition_tree_view">
			<field name="name">od.cost.sheet.inherit</field>
			<field name="model">od.cost.sheet</field>
			<field name="arch" type="xml">
				<tree string="Cost Sheet">
				     <field name="number"/>
				     <field name="sum_total_sale" string="Total Sale Value" sum="total"/>
				     <field name="total_gp" sum="Total" />
					<field name="a_total_manpower_sale" sum="Total" />
					<field name="handover_date"/>
					<field name="op_expected_booking"/>
					<field name="name"/>
					<field name="od_customer_id"/>
					<field name="status"/>
					<field name="state" string="State"/>
					<field name="op_stage_id"/>
				</tree>
			</field>
		</record>
    
    
    <record model="ir.ui.view" id="od_cost_sheet_in_transition_search_view">
			<field name="name">od.cost.sheet.search.intransition</field>
			<field name="model">od.cost.sheet</field>
			<field name="arch" type="xml">
				<search>
					<field name="sales_acc_manager"/>
					<field name="status"/>
					<field name="state"/>
                    <group expand="0" string="Group By" colspan="16">
                        <filter string="Branch" context="{'group_by':'od_branch_id'}"/>
                        <filter string="Technology Unit" context="{'group_by':'od_division_id'}"/>
                         <filter name= "state" string="State" context="{'group_by':'state'}"/>
                         <filter string="Advance Payment" context="{'group_by':'adv_payment_status'}"/>
                        <filter string="Approved Month" context="{'group_by':'approved_date:month'}"/>
                        <filter string="Approved Quarter" context="{'group_by':'approved_date:quarter'}"/>
                        <filter string="Approved Year" context="{'group_by':'approved_date:year'}"/>
                        <filter string="SAM" name="sam" context="{'group_by':'sales_acc_manager'}"/>
                        <filter string="BDM" context="{'group_by':'business_development'}"/>
                        
                        <filter string="Pre-Sales" context="{'group_by':'pre_sales_engineer'}"/>
                        <filter string="Owner" context="{'group_by':'reviewed_id'}"/>
                        <filter string="Company" context="{'group_by':'company_id'}"/>
                        <filter string="Channel" domain="[]" context="{'group_by':'medium_id'}"/>
                        <filter string="Source" domain="[]" context="{'group_by':'source_id'}"/>
                        <separator orientation="vertical"/>
                        <filter string="Creation Month" context="{'group_by':'create_date:month'}" name="Month"/>
                        <filter string="Creation Quarter" context="{'group_by':'create_date:quarter'}" name="Quarter"/>
                        <filter string="Creation Year" context="{'group_by':'create_date:year'}" name="Year"/>
                        <filter string="Expected Month" context="{'group_by':'op_expected_booking:month'}"/>
                        <filter string="Expected Quarter" context="{'group_by':'op_expected_booking:quarter'}"/>
                        <filter string="Expected Year" context="{'group_by':'op_expected_booking:year'}"/>
                     <!--   <filter string="Expected Closing" context="{'group_by':'date_deadline'}"/>  -->
                    </group>
				</search>
			</field>
		</record>
    
			<record model="ir.actions.act_window" id="action_in_transition_cost_sheet">
                <field name="name">In-Transition</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">od.cost.sheet</field>
                <field name="view_type">form</field>
                <field name="domain">[('status','=','active'),('state','in',('handover','waiting_po','waiting_po_open','returned_by_pmo','returned_by_fin'))]</field>
                <field name="view_mode">tree,form,graph</field>
                <field name="view_id" ref="od_cost_sheet_transition_tree_view"/>
                <field name="context">{ 'search_default_state': True, 'search_default_sam': True} </field>
                <field name="search_view_id" ref="od_cost_sheet_in_transition_search_view"/>
                 <field name="help" type="html">
                  <p class="oe_view_nocontent_create">
                    Click to add new Cost Sheet.
                  </p>
                </field>
            </record>
            
            <menuitem
         	
			id="menu_in_transition_cost_sheet"
			parent="orchid_cost_sheet.technology_rpt_gne"
			sequence="100" 
			action="action_in_transition_cost_sheet" />
			
</data>
</openerp>