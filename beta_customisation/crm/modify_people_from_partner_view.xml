<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data>

        <record id="wiz_modify_contact_form_part" model="ir.ui.view">
            <field name="name">Modify People</field>
            <field name="model">wiz.modify.contact.part</field>
            <field name="arch" type="xml">
                <form string="Assign" >
                    
                    <group>
                    <field name="partner_id" readonly="1" invisible="0"/>
                     </group>
                     
                     <group>
                     <field name="wiz_line" nolabel="1" context="{'default_partner_id': partner_id}">
                            <tree editable="top" delete="false" create="false">
                            	<field name="partner_id" invisible="1"/>
                                <field name="name" required="0"/>
                                <field name="function" required="0"/>
                                <field name="email" required="0"/>
                                <field name="mobile" required="0"/>
                                <field name="phone" required="0"/>
                             </tree>
                        </field>
                        </group>
                    
                <footer>
                  <button name="modify_contact" string="Modify" type="object" class="oe_highlight"/>
                    or
                  <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
                </form>
            </field>
        </record>
        


    </data>
</openerp>