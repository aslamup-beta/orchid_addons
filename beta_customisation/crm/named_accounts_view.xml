        <record model="ir.actions.act_window" id="action_organisation_supplier_for_partner_level">
                <field name="name">Organisations-Suppliers</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">res.partner</field>
                <field name="view_type">form</field>
                <field name="domain">[('is_company','=',True),('customer','=',False),('supplier','=',True)]</field>
