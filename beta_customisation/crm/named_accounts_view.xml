                    <field name="city"> </field>
                    <field name="state_id" invisible="1"/>
                    <field name="country_id" invisible="1"/>
                    <field name="website" invisible="1"> </field>
                    <field name="phone" invisible="1"> </field>
                    <field name="use_parent_address" invisible="1"> </field>
                </tree>
			</field>
		</record>
        
