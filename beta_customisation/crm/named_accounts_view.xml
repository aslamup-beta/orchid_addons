<!--         Organisation Customer         -->
                
          <record model="ir.ui.view" id="od_organisation_customer_tree_view">
			<field name="name">res.partner.inherit</field>
			<field name="model">res.partner</field>
			<field name="arch" type="xml">
				<tree string="Organisations-Customers" create="false">
                    <field name="display_name"/>
                    <button name="btn_open_partner" type="object" icon="STOCK_FIND" string="Open" />
                    <field name="is_company" invisible="1"/>
                    <field name="parent_id" invisible="1"/>
                    <field name="od_industry_id"/>
                    <field name="is_company" invisible="1"> </field>
                    <field name="city" invisible="1"> </field>
                    <field name="od_class"/>
                    <field name="country_id" invisible="1"/>
                    <field name="website" invisible="1"> </field>
                    <field name="user_id"> </field>
                    <field name="od_territory_id"/>
                    <field name="phone" invisible="1"> </field>
                    <field name="use_parent_address" invisible="1"> 
                    </field>
                </tree>
			</field>
		</record>
        
        <record id="od_view_named_account_filter" model="ir.ui.view">
            <field name="name">res.partner.select1</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <search string="Search Partner">
                   <field name="name"
                       filter_domain="['|','|',('display_name','ilike',self),('ref','=',self),('email','ilike',self)]"/>
                   <filter help="My Partners" icon="terp-personal+" domain="[('user_id','=',uid)]"/>
                   <separator/>
                   <filter string="Persons" name="type_person" domain="[('is_company','=',0)]"/>
                   <filter string="Companies" name="type_company" domain="[('is_company','=',1)]"/>
                   <separator/>
                   <filter string="Customers" name="customer" domain="[('customer','=',1)]" help="Customer Partners"/>
                   <separator/>
                   <field name="category_id" string="Tag" filter_domain="[('category_id','ilike', self)]"/>
                   <field name="user_id"/>
                   <field name="parent_id" domain="[('is_company','=',1)]" operator="child_of"/>
                   <group expand="0" string="Group By">
                       <filter string="Customer AM" icon="terp-personal" domain="[]" context="{'group_by' : 'user_id'}" />
                       <filter string="Company" context="{'group_by': 'parent_id'}"/>
                       <filter string="Country" context="{'group_by': 'country_id'}"/>
                       <filter string="Industry" context="{'group_by': 'od_industry_id'}"/>
                       <filter string="City" context="{'group_by': 'city'}"/>
                       <filter string="Class" name="class" context="{'group_by':'od_class'}"/>
                   </group>
               </search>
            </field>
        </record>
        
        
        <record model="ir.actions.act_window" id="action_named_accounts_for_partner_level">
                <field name="name">Organisation-Customers</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">res.partner</field>
                <field name="view_type">form</field>
                <field name="domain">[('is_company','=',True),('customer','=',True)]</field>
                <field name="view_mode">tree</field>
                <field name="view_id" ref="od_organisation_customer_tree_view"/>
                <field name="search_view_id" ref="od_view_named_account_filter"/>
                 <field name="help" type="html">
                  <p class="oe_view_nocontent_create">
                    Click to add new Named Accounts.
                  </p>
                </field>
            </record>
        
    <menuitem id="named_accounts_parent" name="Named Accounts" parent="base.menu_base_partner" sequence="1"/>
    <menuitem id="named_accounts" name="Named Accounts Management" action="action_named_accounts_form" parent="beta_customisation.named_accounts_parent" sequence="10"/>
    <menuitem id="named_accounts_list" name="Organisations-Customers" action="action_named_accounts_for_partner_level" parent="mail.mail_my_stuff" sequence="201"/>
    
<!--     Organisation Supplier -->
    
    <record model="ir.ui.view" id="od_organisation_supplier_tree_view">
