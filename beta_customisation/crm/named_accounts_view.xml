<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
        <record model="ir.ui.view" id="named_accounts_tree_view">
            <field name="name">named.accounts.tree</field>
            <field name="model">named.accounts</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="branch_id"/>
                    <field name="company_id"/>
                    <field name="approval_state"/>
                </tree>
           </field>
        </record>
        
        <record id="named_accounts_form_view" model="ir.ui.view">
            <field name="name">named.accounts.form</field>
            <field name="model">named.accounts</field>
            <field name="arch" type="xml">
            <form string="Named Accounts">
            <header>
		            <field name="submit" invisible="1" />
		            <field name="approval" invisible="1" />
		            <field name="change1" invisible="1" />
		            <button name="btn_submit" type="object" class="oe_highlight" groups="orchid_beta.groups_beta_admin,__export__.res_groups_190,__export__.res_groups_192,orchid_beta.group_executive_management_beta_1" string="Submit" attrs="{'invisible':['|',('submit','=',True),('approval_state','=','change')]}"/>
		            <button name="btn_submit_change" type="object" class="oe_highlight" groups="orchid_beta.groups_beta_admin,__export__.res_groups_190,__export__.res_groups_192,orchid_beta.group_executive_management_beta_1" string="Submit Change" attrs="{'invisible':[('approval_state','!=','change')]}"/>
		            <button name="btn_approval" type="object" class="oe_highlight" groups="__export__.res_groups_191" string="Approve" attrs="{'invisible':[('approval_state','!=','pending')]}"/>
		            <button name="btn_change" type="object" class="oe_highlight" groups="orchid_beta.groups_beta_admin,__export__.res_groups_192,__export__.res_groups_190,__export__.res_groups_191" string="Change" attrs="{'invisible':[('approval_state','=','change')]}"/>
		           	<button name="btn_approve_change" type="object" class="oe_highlight" groups="__export__.res_groups_191" string="Approve Change" attrs="{'invisible':[('approval_state','!=','approve_change')]}"/>
		           	<field name="approval_state" widget="statusbar" statusbar_visible="pending"/>
            </header>
            <sheet>
                <div class="oe_title">
                    <label for="name" class="oe_edit_only"/>
                    <h1>
                        <field name="branch_id" invisible="1" attrs="{'readonly':[('submit','=',True)]}"/>
                        <field name="name" required="1" attrs="{'readonly':[('submit','=',True)]}"/>
                    </h1>
                </div>
				<group>
              		<group col="4">
                		</group>
             		<group col="4">
                    		<field name="select_all" attrs="{'readonly':[('submit','=',True)]}"/>
                		</group>
				</group>            
				<group>
            	<notebook>
               		<page string="Named Accounts">
               			<field name="named_accounts_lines" attrs="{'readonly':[('submit','=',True)]}">
                 		<tree editable="bottom" delete="false" colors="gray:remove == True;">
                               <field name="account_id"/>
                               <field name="user_id"/>
                               <field name="od_part_class"/>
                              <field name="remove"/>                                
                         </tree>
               			</field>
               		<group string="New Added Accounts">
               			<field name="new_added_named_account_ids" attrs="{'readonly':[('submit','=',True)]}" nolabel="1">
               				<tree editable="bottom">
	                				<field name="name" string="Account Name"/>
	                 			<field name="user_id" />
 	                 			<field name="od_class" />
              				</tree>
               			</field>
               		</group>
               		</page>
               </notebook>
            	</group>
           	</sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                </form>
            </field>
         </record>
         
         <record model="ir.actions.act_window" id="action_named_accounts_form">
            <field name="name">Named Accounts</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">named.accounts</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
             <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to Create Named Accounts List.
              </p>
            </field>
        </record>
        
