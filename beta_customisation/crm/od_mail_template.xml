<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data noupdate="1">
    
    	<record id="od_pending_legal_leaves" model="email.template">
             <field name="name">UAE - Remaining Leave Days</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Remaining Leave Days</field>
             <field name="email_to">${object.work_email}</field>
<!--              <field name="email_cc">${object.parent_id.work_email}, ${object.coach_id.work_email}</field> -->
             <field name="model_id" ref="model_hr_employee"/>
             <field name="body_html"><![CDATA[
          
          <div style="background-color: rgb(255, 255, 255);">
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Dear ${object.user_id.name or ''},</p>
			 <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Your Leaves Balance up to date is ${ctx["pending_days"]}</p>
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Thank You</p>

         </div>
             ]]>
             </field>
         </record>
         
         <record id="od_pending_legal_leaves_saudi" model="email.template">
             <field name="name">KSA - Remaining Leave days</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Remaining Leave Days</field>
             <field name="email_to">${object.work_email}</field>
<!--              <field name="email_cc">${object.parent_id.work_email}, ${object.coach_id.work_email}</field> -->
             <field name="model_id" ref="model_hr_employee"/>
             <field name="body_html"><![CDATA[
          
          <div style="background-color: rgb(255, 255, 255);">
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Dear ${object.user_id.name or ''},</p>
			 <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Your Leaves Balance up to date is ${ctx["pending_days"]}</p>
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Thank You</p>

         </div>
             ]]>
             </field>
         </record>
         
         <record id="od_probation_period_end_date" model="email.template">
             <field name="name">All - Probation Period End Date</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Probation Period End Date - ${object.user_id.name}</field>
             <field name="email_to">${object.parent_id.work_email}</field>
             <field name="email_cc">${object.coach_id.work_email}</field>
             <field name="model_id" ref="model_hr_employee"/>
             <field name="body_html"><![CDATA[
          
          <div style="" --="">
             <p style="">Dear,</p><p style="">This is a notification email related to probation period of :</p><p style=""></p><ul style=""><li style="">Name of employee:&nbsp;${object.user_id.name}</li><li style="">Joining Date :&nbsp;${object.od_joining_date}</li><li style="">Probation period :&nbsp;${ctx["trail_end_date"]}</li></ul>
			   </div>
             ]]>
             </field>
         </record>
         
         <record id="od_contract_end_date" model="email.template">
             <field name="name">KSA - Contract End Date</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">End of Contract - ${object.employee_id.name}</field>
             <field name="email_to">${object.employee_id.parent_id.work_email},${object.employee_id.od_branch_id.email}</field>
             <field name="email_cc">${object.employee_id.coach_id.work_email}</field>
             <field name="model_id" ref="model_hr_contract"/>
             <field name="body_html"><![CDATA[
          
          
          
          <div style="" --="">
             <p style="">Dears,</p><p style="">This is a notification that the contract of the below employee will expire in 90 days. It will be renewed automatically, unless you terminate it.</p><p style=""></p><ul style=""><li style="">Name of employee:&nbsp;${object.employee_id.name}</li><li style="">Contract Type: Limited</li><li style="">Job Title: ${object.employee_id.job_id.name}</li><li style="">Joining Date :&nbsp;${object.trial_date_start}</li><li style="">Contract Duration End Date: ${object.date_end}</li></ul><div>Thank You</div>
			   </div>
             
             
             ]]>
             </field>
         </record>
         
         
     </data>
</openerp>
