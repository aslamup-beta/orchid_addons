        <!--     Opportunity return request wizard form view
                 -->
        <record id="wiz_lead_request_return_form" model="ir.ui.view">
            <field name="name">wiz.lead.request.return.form</field>
            <field name="model">wiz.lead.request.return</field>
            <field name="arch" type="xml">
                <form string="Request Return">


                    <group string="Please select a destination stage in the below field..">
                        <field name="destination_stage_id" required="1" domain="[('id','in',(1,12))]"/>
                    </group>

                    <footer>
                        <button name="send_return_req" string="Request Return" type="object" class="oe_highlight"/>
                        or
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

