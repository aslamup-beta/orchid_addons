<?xml version="1.0" encoding='UTF-8'?>
<openerp>
    <data noupdate="0">
    <record id="od_lead_weekly_cron_email_template" model="email.template">
        <field name="name">UAE - Lead Weekly Reminder</field>
        <field name="email_from">erp@betait.net</field>
        <field name="subject">${ctx["subject"]}</field>
        <field name="email_to">${ctx["lead_am"]}</field>
        <field name="email_cc">${ctx["manager"]}</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="auto_delete" eval="True"/>
        <field name="body_html"><![CDATA[

                % macro costsheet_table(values):
                <table cellspacing="1" border="1" cellpadding="4">
                <tr>
                    <th>Lead Name</th>
                    <th>Customer</th>
                    <th>Link</th>
                </tr>
                        % for lead in values:
                    <tr>
                        <td>${lead.get('name','')}</td>
                        <td>${lead.get('customer','')}</td>
                        <td>${lead.get('hyper_link','')}</td>
                    </tr>

                % endfor
                </table>
                % endmacro

				<h3>Dear ${ctx["lead_am_name"]},</h3>
                <h3>${ctx["title"]}</h3>
                ${costsheet_table(ctx["data"])}
                <p>
                Thanks,
                </p>
                <pre>                --
                Beta Automatic Email
                </pre>

        ]]></field>
    </record>
      

