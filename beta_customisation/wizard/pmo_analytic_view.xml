<?xml version="1.0"?>
<openerp>
    <data>
  
        <record id="view_pmo_anal_rpt_wizard" model="ir.ui.view">
            <field name="name">PMO Analytic Form</field>
            <field name="model">pmo.anal.rpt.wiz</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report" >
                      <group>
                      	<field name="prj_status" required="1"/>
                      </group>
                
                     <group>                 
                         
                        <group>
                        	<field name="date_start_from"/>
                        	<field name="date_start_to"/>
                         </group>
                         
                          <group>
                        		<field name="closing_date_from" attrs="{'invisible':[('prj_status','=','open')]}"/>
                        		<field name="closing_date_to" attrs="{'invisible':[('prj_status','=','open')]}"/>
                        	</group>
                       </group>
                         
                       
                       <footer>
                       <button name="export_rpt" string="Export" type="object" />
                       or
                        <button string="Cancel" special="cancel" />
                       
                       </footer>
                        
                </form>
            </field>
        </record>

       

        <record id="action_pmo_anal_rpt_act" model="ir.actions.act_window">
            <field name="name">PMO Analytic Report</field>
            <field name="res_model">pmo.anal.rpt.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
         
         
         <menuitem
         	
			id="menu_action_pmo_anal_rpt_act"
			parent="account.menu_finance_reports"
			 sequence="206" 
			action="action_pmo_anal_rpt_act" />


	<record model="ir.ui.view" id="od_pmo_anal_data_tree_view">
		<field name="name">pmo.anal.rpt.data.tree</field>
		<field name="model">pmo.anal.rpt.data</field>
		<field name="arch" type="xml">
			<tree string="Analytic Analysis">
				<field name="analytic_id" />
				<button name="btn_open" type="object" icon="STOCK_FIND" string="Open" />
				<field name="paid"  sum="Total"/>
				<field name="manpower_cost" sum="Total" />
				<field name="general_cost" sum="Total" />
				
				<field name="collected" sum="Total" />
				<field name="project_value" sum="Total" />
				<field name="inv_amount" sum="Total" />
			</tree>
		</field>
	</record>

