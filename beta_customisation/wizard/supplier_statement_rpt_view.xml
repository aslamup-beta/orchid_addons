<?xml version="1.0"?>
<openerp>
    <data>
  
        <record id="view_supplier_statement_rpt_wizard" model="ir.ui.view">
            <field name="name">Supplier Statement</field>
            <field name="model">supplier.statement.rpt.wiz</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report" >
                     
                         <group>
                          <field name="partner_id" required="1" domain="[('supplier','=',True),('is_company','=',True)]"/>
                         </group>
                         
                           <group/>
                            <group/>
                       
                       
                       <footer>
                       <button name="export_rpt" string="Export" type="object" />
                       or
                        <button name="print_directly" string="Print" type="object" />
                       or
                        <button string="Cancel" special="cancel" />
                       
                       </footer>
                        
                </form>
            </field>
        </record>

       

        <record id="action_supplier_statment_rpt_act" model="ir.actions.act_window">
            <field name="name">Supplier Statement</field>
            <field name="res_model">supplier.statement.rpt.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        
        <record model="ir.values" id="part_form_supp_statment_rpt">
            <field name="model_id" ref="base.model_res_partner" />
            <field name="name">Supplier Statement Report</field>
            <field name="key2">client_print_multi</field>
            <field name="value" eval="'ir.actions.act_window,' + str(ref('action_supplier_statment_rpt_act'))" />
            <field name="key">action</field>
            <field name="model">res.partner</field>
        </record>
         
         
        <menuitem 
         	
			id="od_menu_supplier_statement_rpt1"
			parent="account.menu_finance_reports"
			sequence="200" 
			action="action_supplier_statment_rpt_act" />
			
			<menuitem 
         	
			id="od_menu_supplier_statement_rpt2"
			parent="beta_invoice.sup_aging_rpt_gne"
			sequence="2" 
			action="action_supplier_statment_rpt_act" />
			
			<record id="od_supplier_statement_data_form_view" model="ir.ui.view">
            <field name="name">od.supplier.statement.rpt.data.form</field>
            <field name="model">od.supplier.statement.rpt.data</field>
            <field name="arch" type="xml">
            <form string="Supplier Form">
            <header>
				<button name="print_supplier_statement" type="object" class="oe_highlight" string="Print"/>
            </header>
            	<sheet>
	    			
                <group>
		               <field name="partner_id" />
		                        
                </group>
                
                <br/>
                 <br/>
                 
                 <table style="width:100%" class="table table-striped">
								<thead>
									<th>
									</th>
									<th>0-30</th>
									<th>30-60</th>
									<th>60-90</th>
									<th>90-120</th>
									<th>120-150</th>
									<th>150-180</th>
									<th>180+</th>
									<th>Total</th>
									
								</thead>
								<tbody>
								<tr>
	                                  <td>Balance</td>
	                                   <td class="text-right"><field name="bal1" /></td>
	                                   <td class="text-right"><field name="bal2" /></td>
	                                   <td class="text-right"><field name="bal3" /></td>
	                                   <td class="text-right"><field name="bal4" /></td>
	                                    
	                                   <td class="text-right"><field name="bal5" /></td>
	                                   <td class="text-right"><field name="bal6" /></td>
	                                   <td class="text-right"><field name="bal7" /></td>
	                                   <td class="text-right"><field name="total" /></td>
									</tr>
<!-- 									<tr> -->
<!-- 	                                  <td>Amount</td> -->
<!-- 	                                   <td><field name="due1" /></td> -->
<!-- 	                                   <td><field name="due2" /></td> -->
<!-- 	                                   <td><field name="due3" /></td> -->
<!-- 	                                   <td><field name="due4" /></td> -->
	                                    
<!-- 	                                   <td><field name="due5" /></td> -->
<!-- 	                                   <td><field name="due6" /></td> -->
<!-- 	                                   <td><field name="due7" /></td> -->
<!-- 	                                   <td></td> -->
<!-- 									</tr> -->
<!-- 									<tr> -->
<!-- 									<td>Paid</td> -->
<!-- 	                                   <td><field name="paid1" /></td> -->
<!-- 	                                   <td><field name="paid2" /></td> -->
<!-- 	                                   <td><field name="paid3" /></td> -->
<!-- 	                                   <td><field name="paid4" /></td> -->
<!-- 	                                   <td><field name="paid5" /></td> -->
<!-- 	                                   <td><field name="paid6" /></td> -->
<!-- 	                                   <td><field name="paid7" /></td> -->
<!-- 	                                   <td></td> -->
<!-- 									</tr> -->
								
								
								</tbody>
                                </table>
                
                	<field name="line_ids" widget="one2many_list" context="{'show_attribute': False}" >
                            <tree string="Statement" >
<!--                                 <field name="s_no"/> -->
                                <field name="date"/>
                                <field name="actual_inv_date"/>
                                <field name="beta_ref"/>
                                <field name="part_ref"/>
                                <field name="age"/>
                                <field name="payment_term_id"/>
                                <field name="due" sum="Total"/>
                                <field name="paid" sum="Total"/>
                                <field name="bal" sum="Total"/>
                                <field name="remark"/>
                                <field name="due_date"/>
                            </tree>
                        </field>
               </sheet>
            	
                </form>
            </field>
         </record>
			
	
    </data>
</openerp>
