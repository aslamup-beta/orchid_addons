    	<record id="od_fill_detail_employee" model="email.template">
             <field name="name">UAE - Employee Personal Data Entry Form</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Update Beta Joining Form</field>
             <field name="email_to">${object.personal_email},${object.work_email}</field>
<!--              <field name="email_cc">${object.od_owner_id.email}</field> -->
             <field name="model_id" ref="model_od_beta_joining_form"/>
             <field name="body_html"><![CDATA[
          
          <div style="background-color: rgb(255, 255, 255);">
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Dear ${object.name or ''},</p>
			<p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Please update your basic profile details by clicking following link !&nbsp;</p><p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">You need the following documents as soft copies to upload in the form,</p><p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;"><br></p><ol><li><span style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Passport</span></li><li><span style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Education Degree</span></li><li><span style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Local ID (if any)</span></li><li><span style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Personal Photo (Passport size)</span></li></ol><p></p><p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;"><a href="http://betait.net/beta_join/${object.id}">http://betait.net/beta_join/${object.id}</a></p>
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Thank You</p>

         </div>
             ]]>
             </field>
         </record>
         
