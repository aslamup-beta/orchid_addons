             <field name="email_cc">${object.n_coach_id.work_email}, ${object.n_parent_id.work_email},aslam.up@betait.net</field>
             <field name="model_id" ref="model_od_beta_role_change_form"/>
             <field name="body_html"><![CDATA[
         <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
             <p>Dear ${object.employee_id.name or ''},</p>
