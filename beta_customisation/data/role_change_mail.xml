<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data noupdate="0">
    
    	<record id="od_role_change_approval" model="email.template">
             <field name="name">UAE - Role Change First Approval Mail</field>
             <field name="email_from"><![CDATA[ERP Notification <erp@en.betait.net>]]></field>
             <field name="subject">Role Change - ${object.employee_id.name}</field>
             <field name="email_to">${object.parent_id.parent_id.work_email}</field>
             <field name="model_id" ref="model_od_beta_role_change_form"/>
             <field name="body_html"><![CDATA[
          
          <div style="background-color: rgb(255, 255, 255);">
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Dear ${object.parent_id.parent_id.name or ''},</p>
             <p>Please approve role change of the employee</p>
             <p style="color: rgb(34, 34, 34); font-family: &quot;Lucica Grande&quot;, Ubuntu, Arial, Verdana, sans-serif; font-size: 12px;">Thank You</p>

         </div>
             ]]>
             </field>
         </record>
         
