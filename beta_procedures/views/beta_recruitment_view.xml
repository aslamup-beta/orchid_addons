<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
	    <record model="ir.ui.view" id="od_recruitment_process_tree_view">
	        <field name="name">recruitment.process.tree</field>
	        <field name="model">recruitment.process</field>
	        <field name="arch" type="xml">
	            <tree>
	            	<field name="job_id" />
	            	<field name="req_join_date" />
	            	<field name="budget"/>
	            	<field name="state"/>
	            </tree>
	       </field>
	    </record>
	    
        <record id="od_recruitment_process_form_view" model="ir.ui.view">
            <field name="name">recruitment.process.form</field>
            <field name="model">recruitment.process</field>
            <field name="arch" type="xml">
            <form string="Recruitment Form">
            <header>
				<button name="send_to_hiring_manager" type="object" class="oe_highlight" string="First Approval" attrs="{'invisible':[('state', '!=', 'draft')]}"/>
				<button name="send_to_hr" type="object" class="oe_highlight" string="Second Approval" attrs="{'invisible':[('state', '!=', 'second_app')]}"/>
				<button name="reject" type="object" class="oe_highlight" string="Reject" />
                <field name="state" widget="statusbar" statusbar_visible="draft, hiring,second_app," statusbar_colors='{"confirm":"blue"}'/>
            </header>
            <sheet>
            	<div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="job_id" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
                            </h1>
                           
                        </div>
            	
                <group>
	               
	               <group string="Initation Phase">
<!-- 	               		<field name="job_id" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/> -->
	                   <field name="description" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                  <field name="approval_manager1" string="First Approval Manager -مدير الاعتماد الأول" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                  
	                   <field name="approval_manager2" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                   <field name="assesment_req" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                   <field name="req_join_date" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                   <field name="budget" attrs="{'required': [('state','=','hiring')],'readonly':[('state','in','candidate')]}"/>
	                   
	               </group>	               
	               
	               
	               
                </group>
                
                 <notebook>
                 <page string='Candidate Details'>
                        <field name='candidate_line'>
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="email"/>
                                <field name="mobile"/>
                                <field name="linkdin"/>
                                <button name="btn_invite" string="Invite" type="object"/>
                               
                            </tree>
                        </field>
                    </page>
                    <page string='Log History'>
                        <field name='date_log_history_line'>
                            <tree>
                                <field name="name"/>
                                <field name="user_id"/>
                                <field name="date"/>
                            </tree>
                        </field>
                    </page>
                    
                </notebook>
                

               </sheet>
            	<div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                </form>
            </field>
         </record>
         
        <record model="ir.actions.act_window" id="action_od_recruitment_process">
        <field name="name">Recruitment Process</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">recruitment.process</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add new Recruitment form. 
          </p>
        </field>
    	</record>
    
     <menuitem id="od_menu_recruitment_process" name="Recruitment Process" action="action_od_recruitment_process" parent="base.menu_crm_case_job_req_main" sequence="1"/>
    
    
    </data>
</openerp>