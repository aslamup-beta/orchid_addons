<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
<record model="ir.ui.view" id="od_cheque_print_tree">
        <field name="name">od.cheque.print.tree</field>
        <field name="model">od.cheque.print</field>
        <field name="arch" type="xml">
            <tree>
            	<field name="name" />
            	<field name="ref"/>
            	<field name="date"/>
            	<field name="amount"/>
            </tree>
       </field>
    </record>
    		

  <record model="ir.ui.view" id="od_beta_cheque_print_form">
        <field name="name">od.cheque.print.form</field>
        <field name="model">od.cheque.print</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
	                <group col="4">
	                	<field name="custom"/>
	                	<field name="ac_pay"/>
	                	<newline/>
	                	<field name="ref"/>            
		            	<field name="date" required="1"/>
		            	<newline/>
		            	<field name="title"/>
		            	<newline/> 
		            	<field name="partner_id" options="{'no_create': True, 'no_create_edit':True}" attrs="{'invisible':[('custom','=',True)]}"/>
		            	<field name="name" attrs="{'invisible':[('custom','!=',True)]}"/>
		            	<field name="amount" required="1"/>
		            	<newline/>
		            	<field name="amt_words" required="1"/>
		            	<newline/>
		            	<field name="company_id" invisible="1"/>
	                </group>
       			</sheet>
    		</form>
  </field>
 </record>
 
	<record model="ir.actions.act_window" id="action_od_beta_cheque_print">
        <field name="name">Cheque Print</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">od.cheque.print</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add new Cheques
          </p>
        </field>
    </record>
    
     <menuitem id="od_menu_beta_cheque_print" name="Print Cheque" action="action_od_beta_cheque_print" parent="account.menu_finance_bank_and_cash" sequence="200"/>
    
    
    </data>
</openerp>