<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
	    <record model="ir.ui.view" id="view_beta_fin_doc_tree_view">
	        <field name="name">od.finance.doc.tree</field>
	        <field name="model">od.finance.doc</field>
	        <field name="arch" type="xml">
	            <tree>
	            	<field name="name"/>
	            	<field name="issue_date" />
	            	<field name="expiry_date"/>
	            	<field name="company_id"/>
	            </tree>
	       </field>
	    </record>
	    
        <record id="view_beta_fin_doc_form_view" model="ir.ui.view">
            <field name="name">od.finance.doc.form</field>
            <field name="model">od.finance.doc</field>
            <field name="arch" type="xml">
            <form string="Finance Document Form">
            <sheet>
            <div class="oe_right oe_button_box">
            	<button class="oe_inline oe_stat_button" name="od_open_attachement" type="object" icon="fa-book">
					<field name="od_attachement_count" widget="statinfo" string="Documents"/>
				</button>
            </div>       	
               <group>
               		<field name="name" required="1"/>
               		<field name="issue_date" required="1"/>
               		<field name="expiry_date" required="1"/>
               </group>
               
               <div>
	           		<field name="notes" placeholder="Remarks from Finance Dept.."/>
	           </div>
                              
               </sheet>
               
            	<div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                
                </form>
            </field>
         </record>
         
        <record model="ir.actions.act_window" id="action_od_beta_fin_doc_form">
        <field name="name">Finance Document Form</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">od.finance.doc</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
         <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add new Document. 
          </p>
        </field>
    	</record>
    
     	<menuitem id="od_menu_beta_fin_doc" name="Finance Documents" action="action_od_beta_fin_doc_form" groups="__export__.res_groups_200" parent="beta_procedures.menu_company_sub" sequence="12"/>
    
    
    </data>
</openerp>