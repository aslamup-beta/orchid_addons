<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record id="email_template_customer_end_date_reminder_90" model="email.template">
            <field name="name">Outsource Employee - End Date Reminder (90 Days)</field>
            <field name="model_id" ref="beta_customisation.model_outsource_employee"/>
            <field name="subject">Outsource Employee : Customer Contract Ending In 90 Days for ${object.name}</field>
            <field name="email_from">${(user.email or '')|safe}</field>
            <field name="email_to">${object.proj_manager.email}</field>
            <field name="email_cc">fakhri.amaireh@betait.net,hr.ksa@betait.net</field>
            <field name="auto_delete" eval="True"/>
            <field name="body_html"><![CDATA[
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 13px; color: #333;">
                    <p>Dear Team,
                    </p>

                    <p>
                        This is an automated reminder that the customer contract period for the
                        following outsourced employee is set to end in <strong>90 days</strong>.
                    </p>

                    <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
                        <tr>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                <strong>Employee Name</strong>
                            </td>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                ${object.name}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                <strong>Project Manager</strong>
                            </td>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                ${object.proj_manager.name}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                <strong>Cost Sheet</strong>
                            </td>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                ${object.costsheet_id.number}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                <strong>Customer Contract End Date</strong>
                            </td>
                            <td style="padding: 6px; border: 1px solid #ddd;">
                                ${object.end_date}
                            </td>
                        </tr>
                    </table>

                    <p>
                        link: <a>https://erp.betait.net/web?#id=${object.id}&view_type=form&model=outsource.employee&menu_id=1200&action=1879</a>
                    </p>

                    <p style="margin-top: 20px;">
                        Regards,
                        <br/>
                        <t t-out="'ERP Automation System'"/>
                    </p>

                    <p style="font-size: 11px; color: #999; margin-top: 30px;">
                        This is an automated message generated by the system. Please do not reply directly to this
                        email.
                    </p>
                </div>
                ]]>
            </field>
        </record>

