<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="training_card_form_view">
            <field name="name">Training Card</field>
            <field name="model">hr.training.card</field>
            <field name="arch" type="xml">
                <form string="Training Card">
                    <header>
                        <button string="Generate Trainer Contract" type="object" name="action_generate_trainer_contract"
                                class="oe_highlight" groups="__export__.res_groups_256"/>
                    </header>
                    <sheet>
                        <div class="oe_right oe_button_box">
                            <button class="oe_stat_button" name="action_view_trainer_contract" type="object"
                                    string="Trainer Contract" groups="__export__.res_groups_256"
                                    icon="fa-file">
                            </button>
                        </div>
                        <label for="program"/>
                        <div>
                            <field name="program" required="1"/>
                        </div>
                        <label for="code"/>
                        <field name="code" required="1"/>
                        <label for="general_purpose"/>
                        <field name="general_purpose"/>
                        <label for="training_hours"/>
                        <field name="training_hours"/>
                        <label for="program_imp_channel"/>
                        <field name="program_imp_channel"/>
                        <label for="target_audience"/>
                        <field name="target_audience"/>
                        <label for="potential_trainer_id"/>
                        <field name="potential_trainer_id"/>
                        <label for="training_type_id"/>
                        <field name="training_type_id" required="1"/>
                        <label for="department_id"/>
                        <field name="department_id"/>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_training_card_tree_view">
            <field name="name">hr.training.card.tree</field>
            <field name="model">hr.training.card</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree string="Training Card">
                    <field name="program"/>
                    <field name="training_type_id"/>
                    <field name="department_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_training_card_search_view">
            <field name="name">hr.training.card.search.view</field>
            <field name="model">hr.training.card</field>
            <field name="arch" type="xml">
                <search>
                    <field name="program"/>
                    <field name="training_type_id"/>
                    <group expand="1" string="Group By">
                        <filter string="Training Type" domain="[]" context="{'group_by':'training_type_id'}"/>
                        <filter string="Department" name="department_id" domain="[]" context="{'group_by':'department_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_training_card">
            <field name="name">Training Card</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.training.card</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_department_id': 1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <menuitem id="menu_training" name="Training" sequence="110"/>

        <menuitem name="Training" parent="menu_training"
                  id="menu_training_main" sequence="5"/>

        <menuitem name="Training Card" action="action_open_training_card" parent="menu_training_main"
                  id="menu_open_training_card" sequence="8"/>

    </data>
</openerp>
