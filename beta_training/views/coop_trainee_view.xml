            <field name="name">Coop Trainee search view</field>
            <field name="model">coop.trainee</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <group expand="0" string="Group By" colspan="16">
                        <filter string="Customer" context="{'group_by':'customer_id'}"/>
                        <filter string="Project Manager" context="{'group_by':'proj_manager'}"/>
                        <filter string="Contract End Month" context="{'group_by':'end_date:month'}"/>
                        <filter string="Contract End Quarter" context="{'group_by':'end_date:quarter'}"/>
                        <filter string="Contract End Year" context="{'group_by':'end_date:year'}"/>
                    </group>
                </search>
            </field>
        </record>-->


        <record model="ir.actions.act_window" id="action_view_coop_trainee">
            <field name="name">Coop Trainee</field>
            <field name="res_model">coop.trainee</field>
            <field name="view_type">form</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to Create a Coop Trainee
                </p>
            </field>
        </record>


        <menuitem id="menu_coop_trainee_main" name="Coop Trainees"
                  parent="menu_training" sequence="4"
        />

        <menuitem id="menu_coop_trainee" name="Trainees"
                  parent="menu_coop_trainee_main" action="action_view_coop_trainee"/>


    </data>
</openerp>
