<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="trainer_contract_form_view">
            <field name="name">Trainer Contracts</field>
            <field name="model">trainer.contract</field>
            <field name="arch" type="xml">
                <form string="Trainer Contracts" create="false">
                    <header>
                        <button string="Schedule" type="object" name="action_schedule_training" class="oe_highlight"
                                attrs="{'invisible':[('state','=','scheduled')]}" groups="__export__.res_groups_256"
                        />
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_right oe_button_box" groups="base.group_user">
                            <button name="od_view_attendees" class="oe_inline oe_stat_button" type="object"
                                    icon="fa-list">
                                <field name="attendees_count" widget="statinfo" string="Attendees"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="training_card_id"/>
                                <field name="trainer_id"/>
                                <field name="training_location"/>
                                <field name="venue"/>
                            </group>
                            <group>
                                <field name="user_id" string="Responsible Person"/>
                                <field name="training_type_id"/>
                                <field name="brand_id"/>
                                <field name="company_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Candidates for Training">
                                <field name="attendees_ids">
                                    <tree editable="bottom">
                                        <field name="user_id" required="1"/>
                                        <field name="status" readonly="1"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Training Time">
                                <field name="training_plan_ids">
                                    <tree editable="bottom">
                                        <field name="start_date" required="1"/>
                                        <field name="end_date" required="1"/>
                                        <field name="duration" readonly="1"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Training Budget">
                                <group>
                                    <group>
                                        <field name="budget_per_emp"/>
                                        <field name="additional_budget"/>
                                    </group>
                                    <group>
                                        <field name="total_budget"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_trainer_contract_tree_view">
            <field name="name">trainer.contract.tree</field>
            <field name="model">trainer.contract</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree string="Trainer Contracts" create="false">
                    <!--                    <field name="name"/>-->
                    <field name="training_card_id"/>
                    <field name="user_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_trainer_contract_search_view">
            <field name="name">trainer.contract.search.view</field>
            <field name="model">trainer.contract</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="training_card_id"/>
                    <field name="state"/>
                    <group expand="1" string="Group By">
                        <filter string="Training Name" domain="[]" context="{'group_by':'training_card_id'}"/>
                        <filter string="State" domain="[]" context="{'group_by':'state'}"/>
                        <filter string="Assigned By" domain="[]" context="{'group_by':'user_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_trainer_contract">
            <field name="name">Trainer Contracts</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">trainer.contract</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_open_trainer_contract_form">
            <field name="name">Trainer Contracts</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">trainer.contract</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <menuitem name="Trainer Contracts" action="action_open_trainer_contract" parent="menu_training_main"
                  id="menu_open_trainer_contract" sequence="2" groups="__export__.res_groups_256"/>


    </data>
</openerp>
