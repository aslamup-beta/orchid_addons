<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="employee_idp_form_view">
            <field name="name">employee.idp.form.view</field>
            <field name="model">employee.idp</field>
            <field name="arch" type="xml">
                <form string="Individual Development Plan (IDP)" create="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_user_id" invisible="1"/>
                                <field name="employee_id"/>
                                <field name="manager_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="department_id"/>
                                <field name="coach_id" invisible="1"/>
                                <field name="idp_year"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Training">
                                <separator string="Planned"/>
                                <field name="assign_training_plan_ids">
                                    <tree editable="bottom">
                                        <field name="training_card_id" required="1"/>
                                        <field name="training_type_id"/>
                                        <field name="training_status"/>
                                        <field name="scheduled_date"/>
                                        <field name="employee_status"/>
                                    </tree>
                                </field>
                                <separator string="Confirmed to be Attended by Employee"/>
                                <field name="actual_trainings">
                                    <tree create="false">
                                        <field name="training_card_id" required="1"/>
                                        <field name="training_type_id"/>
                                        <field name="training_status"/>
                                        <field name="scheduled_date"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                                <separator string="Completed"/>
                                <field name="completed_trainings">
                                    <tree create="false">
                                        <field name="training_card_id"/>
                                        <field name="training_type_id"/>
                                        <field name="training_status"/>
                                        <field name="scheduled_date"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_employee_idp_tree_view">
            <field name="name">employee.idp.tree</field>
            <field name="model">employee.idp</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree string="Individual Development Plan (IDP)" create="false">
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="manager_id" invisible="1"/>
                    <field name="coach_id" invisible="1"/>
                    <field name="idp_year"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_employee_idp_search_view">
            <field name="name">employee.idp.search.view</field>
            <field name="model">employee.idp</field>
            <field name="arch" type="xml">
                <search>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="manager_id"/>
                    <field name="coach_id"/>
                    <field name="idp_year"/>
                    <group expand="1" string="Group By">
                        <filter string="Employee" domain="[]" context="{'group_by':'employee_id'}"/>
                        <filter string="Department" domain="[]" context="{'group_by':'department_id'}"/>
                        <filter string="Manager" domain="[]" context="{'group_by':'manager_id'}"/>
                        <filter string="Coach" domain="[]" context="{'group_by':'coach_id'}"/>
                        <filter string="Year" domain="[]" context="{'group_by':'idp_year'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_employee_idp">
            <field name="name">Individual Development Plan (IDP)</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">employee.idp</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <!--<menuitem name="Calendar" action="calendar.action_calendar_event"
                  parent="menu_training_main"
                  id="menu_open_employee_training_calendar" sequence="1"/>-->
        <!--<menuitem name="Dashboard" parent="menu_training"
                  id="menu_contract_main" sequence="0"/>-->

        <menuitem name="IDP" action="action_open_employee_idp"
                  parent="menu_training_main"
                  id="menu_open_employee_idp" sequence="0"/>


    </data>
</openerp>
