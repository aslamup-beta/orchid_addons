<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="training_type_form_view">
            <field name="name">Training Type</field>
            <field name="model">training.type</field>
            <field name="arch" type="xml">
                <form string="Training Type">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_training_type_tree_view">
            <field name="name">training.type.tree</field>
            <field name="model">training.type</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree string="Training Type">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_training_type_search_view">
            <field name="name">training.type.search.view</field>
            <field name="model">training.type</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <!--<group expand="1" string="Group By">
                        <filter string="Employee" domain="[]" context="{'group_by':'employee_id'}"/>
                    </group>-->
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_training_type">
            <field name="name">Training Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">training.type</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <menuitem name="Configuration" parent="menu_training"
                  id="menu_training_configuration" sequence="99"/>

        <menuitem name="Training Type" action="action_open_training_type" parent="menu_training_configuration"
                  id="menu_open_training_type" sequence="10"/>

