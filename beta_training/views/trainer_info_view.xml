<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="trainer_info_form_view">
            <field name="name">Trainer Qualification</field>
            <field name="model">trainer.info</field>
            <field name="arch" type="xml">
                <form string="Trainer Qualification">
                    <header>
                        <button name="send_to_training_committee" type="object" class="oe_highlight"
                                string="Send to Training Commitee" attrs="{'invisible':[('state', '!=', 'draft')]}"/>
                        <button name="confirm_trainer" type="object" class="oe_highlight" string="Confirm Trainer"
                                attrs="{'invisible':[('state', '!=', 'confirm')]}"/>

                        <button string="Refuse" type="object" name="action_refuse"
                                attrs="{'invisible':[('state', '!=', 'confirm')]}"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,confirm,validate,refuse"
                               statusbar_colors='{"confirm":"blue"}'/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" required="1"/>
                            </h1>
                        </div>

                        <group>

                            <group string="Trainer Qualification Information">
                                <field name="nationality"/>
                                <field name="residence"/>
                                <field name="qualification"/>
                                <field name="experience"/>
                            </group>
                        </group>
                        <group string="Training Program Information">
                            <field name="training_title"/>
                            <field name="program_desc"/>
                            <field name="target_audience"/>
                        </group>
                        <group string="Trainer Qualification Criteria">
                            <field name="trn_rel_qualification"/>
                            <field name="previous_experience"/>
                            <field name="trainer_strength1"/>
                            <field name="trainer_strength2"/>
                            <field name="flexibilty"/>
                            <field name="pricing"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_trainer_info_tree_view">
            <field name="name">trainer.info.tree</field>
            <field name="model">trainer.info</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree string="Trainer Qualification">
                    <field name="name"/>
                    <field name="nationality"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_trainer_info_search_view">
            <field name="name">trainer.info.search.view</field>
            <field name="model">trainer.info</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <!--<group expand="1" string="Group By">
                        <filter string="Employee" domain="[]" context="{'group_by':'employee_id'}"/>
                    </group>-->
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_trainer_info">
            <field name="name">Trainer Qualification</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">trainer.info</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <menuitem name="Trainer Qualification" action="action_open_trainer_info" parent="menu_training_main"
                  id="menu_open_trainer_info" sequence="10"/>


    </data>
</openerp>
