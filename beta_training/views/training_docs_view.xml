<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="training_docs_tree">
            <field name="name">training.docs.tree.view</field>
            <field name="model">training.docs</field>
            <field name="arch" type="xml">
                <tree string="Training Documents" editable="top">
                    <field name="sequence" widget="handle"/>
                    <field name="name" required="1"/>
                    <field name="attach_file" filename="attach_fname"/>
                    <field name="attach_fname"/>
                    <field name="issue_date" invisible="1"/>
                    <field name="expiry_date" required="1"/>
                    <field name="company_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_training_docs">
            <field name="name">Training Documents</field>
            <field name="res_model">training.docs</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="training_docs_tree"/>
        </record>

        <menuitem name="Documents" parent="menu_training"
                  id="menu_training_docs_main" sequence="7"/>

		<menuitem id="menu_training_docs" name="Training Documents" action="action_training_docs" parent="menu_training_docs_main" sequence="33"/>


    </data>
</openerp>
