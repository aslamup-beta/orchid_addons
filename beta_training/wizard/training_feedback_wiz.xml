<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="wiz_attach_emp_feedback" model="ir.ui.view">
            <field name="name">Training Feedback</field>
            <field name="model">emp.training.feedback.wiz</field>
            <field name="arch" type="xml">
                <form string="Feedback">
                    <group>
                        <field name="completed_date" required="1"/>
                        <field name="training_feedback" required="1"/>
                        <field name="emp_comments" required="1"/>
                        <field name="attach_file_emp" filename="attach_fname_emp" string="Attach Docs/Certificate"/>
                        <field name="attach_fname_emp" invisible="1"/>
                    </group>
                    <br></br>
                    <br></br>
                    <br></br>
                    <footer>
                        <button name="action_submit" string="Submit" type="object" class="oe_highlight"/>
                        or
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_attach_emp_feedback" model="ir.actions.act_window">
            <field name="name">Employee Feedback</field>
            <field name="res_model">emp.training.feedback.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="wiz_attach_hr_feedback" model="ir.ui.view">
            <field name="name">Training Feedback</field>
            <field name="model">hr.training.feedback.wiz</field>
            <field name="arch" type="xml">
                <form string="Feedback">
                    <group>
                        <field name="hr_feedback" required="1"/>
                        <field name="hr_comments" required="1"/>
                    </group>
                    <br></br>
                    <br></br>
                    <footer>
                        <button name="action_submit" string="Submit" type="object" class="oe_highlight"/>
                        or
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_attach_hr_feedback" model="ir.actions.act_window">
            <field name="name">HR Feedback</field>
            <field name="res_model">hr.training.feedback.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</openerp>