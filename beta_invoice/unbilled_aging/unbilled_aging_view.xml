<?xml version="1.0"?>
<openerp>
    <data>

        <record id="od_view_unbilled_aging_rpt_wizard" model="ir.ui.view">
            <field name="name">Unbilled Customer Aging Form</field>
            <field name="model">od.beta.unbilled.aging.wiz</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                        <group>
                        	<field name="date_from" required="1"/>
                        </group>
                        <group>
                        	<field name="period_length"  required="1"/>
                        </group>
                        <group>
                            <field name="account_ids" widget="many2many_tags" required="1"/>
                        </group>
                         <group />
                         <group />
                        <group>
                        <field name="partner_ids" widget="many2many_tags"/>
                        </group>
                        <br/>
                        <br/>
                        <br/>
                       <footer>
                       <button name="export_rpt" string="Export" type="object" class="oe_highlight"/>
                       or
						   <button name="print_directly" string="Print" type="object" class="oe_highlight"/>
						   or
                        <button string="Cancel" special="cancel" />
                       </footer>
                </form>
            </field>
        </record>

        <record id="od_action_unbilled_aging_rpt_act" model="ir.actions.act_window">
            <field name="name">Unbilled Customer Aging Report</field>
            <field name="res_model">od.beta.unbilled.aging.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
         <menuitem
			id="od_menu_ubilled_aging_rpt"
			parent="customer_aging_rpt_gne"
			sequence="3"
			action="od_action_unbilled_aging_rpt_act" groups="__export__.res_groups_200"/>


	<record model="ir.ui.view" id="od_unbilled_aging_data_tree_view_1">
		<field name="name">od.beta.unbilled.aging.data.tree</field>
		<field name="model">od.beta.unbilled.aging.data</field>
		<field name="arch" type="xml">
			<tree string="Unbilled Customer Aging Report">
			<field name="company_id" invisible="1" />
				<field name="partner_id" />
				<!-- <field name="current" sum="Total" /> -->
				<field name="bal_30_1"  sum="Total" />
				<field name="bal_30_2"  sum="Total" />
				<field name="bal_30_3" sum="Total" />
				<field name="bal_30_4"   sum="Total" />
				<field name="bal_30_5"  sum="Total" />
				<field name="bal_30_6"  sum="Total" />
				<field name="bal_30_plus"  sum="Total" />
				<field name="balance" sum="Total" />
<!--				<field name="open_amount" sum="Total" />-->
<!--				<field name="closed_amount" sum="Total" />-->
				<field name="payment_term_id" />

			</tree>
		</field>
	</record>


	<record model="ir.ui.view" id="od_unbilled_aging_data_tree_view_2">
		<field name="name">od.beta.unbilled.aging.data.tree</field>
		<field name="model">od.beta.unbilled.aging.data</field>
		<field name="arch" type="xml">
			<tree string="Unbilled Aging Report">
			<field name="company_id" invisible="1" />
				<field name="partner_id" />
				<!-- <field name="current" sum="Total" /> -->
				<field name="bal_60_1"  sum="Total" />
				<field name="bal_60_2"  sum="Total" />
				<field name="bal_60_3" sum="Total" />
				<field name="bal_60_4"   sum="Total" />
				<field name="bal_60_5"  sum="Total" />
				<field name="bal_60_6"  sum="Total" />
				<field name="bal_60_plus"  sum="Total" />
				<field name="balance" sum="Total" />
				<field name="payment_term_id" />

			</tree>
		</field>
	</record>


	<record model="ir.ui.view" id="od_unbilled_aging_search_view_1">
		<field name="name">od.beta.unbilled.aging.data.search</field>
		<field name="model">od.beta.unbilled.aging.data</field>
		<field name="arch" type="xml">
			<search>
				<field name="partner_id" />
			<group expand="1" string="Group By">
                        <filter string="Customer" domain="[]" context="{'group_by':'partner_id'}"/>
                    </group>
			</search>
		</field>
	</record>
    </data>
</openerp>