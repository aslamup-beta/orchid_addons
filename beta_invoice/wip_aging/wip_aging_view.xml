	<record model="ir.ui.view" id="od_wip_aging_data_tree_view_1">
		<field name="name">od.beta.wip.aging.datatree</field>
		<field name="model">od.beta.wip.aging.data</field>
		<field name="arch" type="xml">
			<tree string="WIP Aging Report">
			<field name="company_id" invisible="1" />
