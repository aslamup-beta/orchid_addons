	<record model="ir.ui.view" id="oood_higl_lvf_search_view_1">
		<field name="name">wiz.wip.high.level.data.search</field>
		<field name="model">wiz.wip.high.level.data</field>
		<field name="arch" type="xml">
			<search>
				<field name="partner_id" />
				<field name="analytic_id" />
				<group expand="1" string="Group By">
				    <filter name ="partner" string="Customer" domain="[]" context="{'group_by':'partner_id'}"/>             	
                   <filter name ="status" string="Priority" domain="[]" context="{'group_by':'status'}"/>
                   <filter name ="project_type" string="Analytic Type" domain="[]" context="{'group_by':'project_type'}"/>
                </group>
                
			</search>
			</field>
	</record>
	
	
