        <record id="od_view_aging_rpt_wizard_high" model="ir.ui.view">
            <field name="name">Aging Form</field>
            <field name="model">od.beta.customer.aging.wiz.high</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                   
                    
                       
                        <group>
                        	<field name="date_from" />
                        </group>
                        <group>
                        	<field name="period_length"  required="1"/>
                        </group>
                        <group>
                            <field name="branch_ids" widget="many2many_tags"/>
                        </group>
                         <group />
                         <group />
                        <group>
                        <field name="partner_ids" widget="many2many_tags"/>
                        
                        </group>
                        
                        <br/>
                        <br/>
                        <br/>
                        
                        
                      
                   

                      
                       <footer>
                       <button name="export_rpt" string="Export" type="object" />
                       or
                        <button string="Cancel" special="cancel" />
                       
                       </footer>
                        
                </form>
            </field>
        </record>

       

