<?xml version="1.0" encoding='UTF-8'?>
<openerp>
    <data noupdate="0">
    <record id="od_cost_sheet_cron_email_template" model="email.template">
        <field name="name">UAE - Waiting PO/Special Approval from GM Reminder</field>
        <field name="email_from"><![CDATA[ERP Notification <erp@en.betait.net>]]></field>
        <field name="subject">${ctx["subject"]}</field>
        <field name="email_to">khalid.eqtifan@betait.net,mohd.sageer@betait.net,sami.nazzal@betait.net,ramesh.poruppath@betait.net</field>
        <field name="email_cc">${ctx["branch_managers"]}</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="auto_delete" eval="True"/>
        <field name="body_html"><![CDATA[
                Hello ,

                % macro costsheet_table(values):
                <table cellspacing="1" border="1" cellpadding="4">
                <tr>
                    <th>Branch</th>
                    <th>Costsheet</th>
                    <th>Number</th>
                    <th>Customer</th>
                    <th>PO Status</th>
                    <th>Sale Person</th>
                    <th>Owner Name</th>
                </tr>
                        % for costsheet in values:
                    <tr>
                         <td>${costsheet.get('branch','')}</td>
                        <td>${costsheet.get('name','')}</td>
                        <td>${costsheet.get('number','')}</td>
                        <td>${costsheet.get('customer','')}</td>
                        <td>${costsheet.get('po_status','')}</td>
                        <td>${costsheet.get('sale_person','')}</td>
                        <td>${costsheet.get('owner','')}</td>
                    </tr>

                % endfor
                </table>
                % endmacro


                <h2>${ctx["title"]}</h2>
                ${costsheet_table(ctx["data"])}
                <p>
                Thanks,
                </p>
                <pre>                --
                Beta Automatic Email
                </pre>

        ]]></field>
    </record>
      

