                        <button string="Cancel" special="cancel" />
                       
                       </footer>
                        
                </form>
            </field>
        </record>

       

        <record id="action_sale_in_rev_rpt_act" model="ir.actions.act_window">
            <field name="name">Sale In/Technology</field>
            <field name="res_model">opp.sale.in.rpt.wiz</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id"  />
            <field name="target">new</field>
        </record>
         
         
         <menuitem
         	
			id="menu_sale_in_rev_rpt"
			parent="technology_rpt_gne"
			 sequence="2" 
			action="action_sale_in_rev_rpt_act" />


	<record model="ir.ui.view" id="od_rev_sale_in_tree_view">
		<field name="name">wiz.sale.in.data</field>
		<field name="model">wiz.sale.in.data</field>
		<field name="arch" type="xml">
			<tree string="Sale In">
			<field name="company_id" invisible="1" />
				<field name="opp_create_date" />
				<field name="date" />
				<field name="partner_id" />
				<field name="od_class" />
				<field name="stage_id" />
				<field name="cost_sheet_id" />
				<button name="btn_open_cost" type="object" icon="STOCK_FIND" string="Open" />
				<field name="branch_id" />
				<field name="pdt_grp_id" />
				 <field name="po_status" /> 
				<field name="sale_aftr_disc" string="Sales" sum="Total" />
				<field name="total_gp" string="Amended Profit" sum="Total" />
				<field name="original_gp" string="Org Profit" sum="Total" />
				<field name="mp_sales" string="MP Sales" sum="Total" invisible="0"/>
				<field name="bdm_user_id" />
				<field name="sam_id" />
				<field name="lead_am_id"/>
				<field name="pre_sales_engineer" />
				<field name="rebate_amnt" sum="Total" invisible="1"/>
			</tree>
		</field>
	</record>
	
	<record model="ir.ui.view" id="od_rev_sale_in_tree_view_1">
		<field name="name">wiz.sale.in.data</field>
		<field name="model">wiz.sale.in.data</field>
		<field name="arch" type="xml">
			<tree string="Sale In">
			<field name="company_id" invisible="1" />
				<field name="opp_create_date" />
				<field name="date" />
				<field name="partner_id" />
				<field name="od_class" />
				<field name="stage_id" />
				<field name="cost_sheet_id" />
				<button name="btn_open_cost" type="object" icon="STOCK_FIND" string="Open" />
				<field name="branch_id" />
				<field name="pdt_grp_id" />
				<field name="sale_aftr_disc" string="Sales" sum="Total" />
				<field name="total_gp" string="Amended Profit" sum="Total" />
				<field name="original_gp" string="Org Profit" sum="Total" />
				<field name="returned_mp" string="Returned MP" sum="Total"/>
				<field name="mp_sales" string="MP Sales" sum="Total" invisible="1"/>
				<field name="rebate_amnt" sum="Total"/>
				<field name="bdm_user_id" />
				<field name="sam_id" />
				<field name="lead_am_id"/>
				<field name="pre_sales_engineer" />
				<field name="day_rule" />
				<field name="over_rule" />
				<field name="po_status" /> 
				
			</tree>
		</field>
	</record>

	<record model="ir.ui.view" id="ood_rev_sale_in_search_view">
		<field name="name">wiz.sale.in.data.search</field>
		<field name="model">wiz.sale.in.data</field>
		<field name="arch" type="xml">
			<search>
			<field name="date" />
			<field name="opp_id" />
			<field name="stage_id" />
			<field name="cost_sheet_id" />
			<group expand="1" string="Group By">
                        
                        <filter string="Company" domain="[]" context="{'group_by':'company_id'}"/>
                         <filter string="Branch" domain="[]" context="{'group_by':'branch_id'}"/>
                          <filter string="Opp Creation Date" domain="[]" context="{'group_by':'opp_create_date'}"/>
                        <filter string="Technology Unit" domain="[]" context="{'group_by':'pdt_grp_id'}"/>
                        <filter string="Industry" domain="[]" context="{'group_by':'industry_id'}"/>
                        <filter string="Customer" domain="[]" context="{'group_by':'partner_id'}"/>
                         <filter string="Customer AM" domain="[]" context="{'group_by':'sam_id'}"/>
                          <filter string="Lead AM" domain="[]" context="{'group_by':'lead_am_id'}"/>
                          <filter string="Class" domain="[]" context="{'group_by':'od_class'}"/>
                          <filter string="Pre-Sales Engineer" domain="[]" context="{'group_by':'pre_sales_engineer'}"/>
                         <filter string="Created By" domain="[]" context="{'group_by':'bdm_user_id'}"/>
                        <filter string="Stage" domain="[]" context="{'group_by':'stage_id'}"/>
                        <filter string="Cost Sheet" domain="[]" context="{'group_by':'cost_sheet_id'}"/>
                        <filter string="PO Status" domain="[]" context="{'group_by':'po_status'}"/>
                        <filter string="Approved Month" context="{'group_by':'date:month'}"/>
                        <filter string="Approved Quarter" context="{'group_by':'date:quarter'}"/>
                        <filter string="Approved Year" context="{'group_by':'date:year'}"/>
                       
                    </group>
			
			</search>
			
			
		</field>
	</record>
    </data>
</openerp>
