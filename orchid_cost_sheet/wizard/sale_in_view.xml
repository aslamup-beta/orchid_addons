        <record id="view_sale_in_rev_rpt_wizard" model="ir.ui.view">
            <field name="name">Sale IN</field>
            <field name="model">opp.sale.in.rpt.wiz</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                    <group >
                      
                        <group>
	                        <field name="date_start" />
	                        <field name="date_end" />
	                        <field name="company_id" invisible="1"/>
                        </group>
                         <group >
                       	 <field name="lead_date_start" />
	                        <field name="lead_date_end" />
                        </group>
                         <group >
                       	 <field name="submit_to_cust_date_start" />
	                        <field name="submit_to_cust_date_end" />
                        </group>
                        
                      
                       </group>
                        
                        	   <group>
                        	        <field name="branch_ids" widget="many2many_tags"/>
                        	    </group>
                        	    <group></group>
                        	    <group></group>
                           <group>
                               <field name="product_group_ids" widget="many2many_tags" string="Technology Unit"/>
                           </group>
                             <group></group>
                        	    <group></group>
                           <group>
                           <field name="sm_ids" widget="many2many_tags" context="{'sam_ids':1}" groups="orchid_beta.groups_beta_admin,__export__.res_groups_192,orchid_beta.group_sale_department_mananger,__export__.res_groups_188, __export__.res_groups_200,__export__.res_groups_238"/>
                           </group>
                             <group></group>
                        	    <group></group>
                        	    
<!--                         	    <group> -->
<!--                                <field name="copy_cust_am" string="Lead AM(Same as Customer AM)"/> -->
<!--                             </group> -->
<!--                               <group></group> -->
<!--                         	    <group></group> -->
                        	    
                        	    
                        	    <group>
                                 <field name="lead_am_ids" groups="orchid_beta.groups_beta_admin,__export__.res_groups_192,orchid_beta.group_sale_department_mananger,__export__.res_groups_188, __export__.res_groups_200,__export__.res_groups_244,__export__.res_groups_238,__export__.res_groups_172,__export__.res_groups_239" widget="many2many_tags" context="{'sam_ids':1}"/>
                             </group>
                               <group></group>
                        	    <group></group>
                        	    
                        	    <group>
                         		<field name="cust_ids" widget="many2many_tags"/>
		                        </group>
		                         <group></group>
		                        <group></group>
                        	
                        	 <group>
                           <field name="presale_ids" widget="many2many_tags" groups="orchid_beta.groups_beta_admin,__export__.res_groups_192,orchid_beta.group_sale_department_mananger,__export__.res_groups_188, __export__.res_groups_200,__export__.res_groups_172" context="{'solution_arch_ids':1}"/>
                           </group>
                             <group></group>
                        	    <group></group>
                        	
                        	
                        	
                        		 <group>
                        		 <field name="created_by_ids" widget="many2many_tags" context="{'sam_ids':1}" groups="orchid_beta.groups_beta_admin,__export__.res_groups_192,orchid_beta.group_sale_department_mananger,__export__.res_groups_188, __export__.res_groups_200"/>
                        		 </group>
                        		 
                        		  <group></group>
		                        <group></group>
                        		 
                        		 <group>
                        		 <field name="costsheet_id" domain =" [('status','=','active'),('state','in',('approved','done','modify','change','analytic_change','change_processed','redistribution_processed'))]"/>
                        		 </group>
                        		 
                        		 <group></group>
		                         <group></group>
		                        
		                        <group>
                               <field name="industry_ids" widget="many2many_tags" string="Industry"/>
                           		</group>
                        		 	<group></group>
		                         	<group></group>
		                         	<group></group>
		                         	<group></group>
                        		    <group />
                              <group />
                        		
                       
                       
                     

                      
                       <footer>
                       <button name="export_rpt" string="Export" type="object" />
