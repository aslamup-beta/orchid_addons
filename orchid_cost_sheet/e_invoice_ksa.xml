<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
    
        <template id="external_layout_header_footer">
             <t t-foreach="docs" t-as="o">
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
        <div class="header no-bg">
            <div class="row">
                <div class="col-xs-2">
                   <t t-foreach="o.company_id.header_image" t-as="image">
				<t t-if="image.name=='beta logo'">
			   <img t-if="image.img" style="max-height: 60px;"
			        t-att-src="'data:image/png;base64,%s'%image.img"
			        alt="BETA_IT"/>
					</t>
				</t>
                </div>
                <div class="col-xs-8 text-left">
                    <p class="Amiri"> شركة دار بيتا لتكنولوجيا المعلومات </p>
                    <p class="Poppins">Dar Beta Information Technology Co.</p>
                </div>
                <div class="col-xs-2">
                    <p class="Amiri">فاتورة ضريبية</p>
                    <p class="Poppins">Tax Invoice</p>
                </div>
            </div>
            <div class="row">
                <div class="col-xs-10">
                    <table class="table table-bordered-light table-sm">
                        <tbody class="sale_tbody">
                            <tr>
                                <td class="Poppins">Invoice number</td>
                                <td class="text-center Poppins" t-esc="o.number"/>
                                <td class="text-right Amiri">رقــم الفاتورة</td>
                            </tr>
                            <tr>
                                <td class="Poppins">Invoice Issue Date</td>
                                <td class="text-center Poppins" t-esc="o.date_invoice"
                                    t-field-options="{&quot;format&quot;: &quot;dd.MM.yyyy&quot;}"/>
                                <td class="text-right Amiri">تاريخ اصدار الفاتورة</td>

                            </tr>
                            <tr>
                            <t t-if="not o.display_contract_no">
                                <td class="Poppins">Date of supply</td>
                                <td class="text-center Poppins" t-esc="o.bt_supply_date"/>
                                <td class="text-right Amiri">تاريخ التوريد</td>
                            </t>
                            </tr>
                            <tr>
                            <t t-if="not o.display_contract_no">
                                <td class="Poppins">PO #</td>
                                <td class="text-center Poppins" t-esc="o.bt_po_ref"/>
                                <td class="text-right Amiri">رقم التعميد</td>
                            </t>
                            </tr>
                            <tr>
                            <t t-if="o.display_contract_no">
                                <td class="Poppins">Contract #</td>
                                <td class="text-center Poppins" t-esc="o.contract_no"/>
                                <td class="text-right Amiri">عقد رقم</td>
                            </t>
                            </tr>
                            <tr>
                            <t t-if="o.display_contract_no">
                                <td class="Poppins">Service W.O</td>
                                <td class="text-center Poppins" t-esc="o.service_wo"/>
                                <td class="text-right Amiri">عقد رقم</td>
                                </t>
                            </tr>
                            <tr>
                                <td class="Poppins">Due Date</td>
                                <td class="text-center Poppins" t-esc="o.date_due"
                                    t-field-options="{&quot;format&quot;: &quot;dd.MM.yyyy&quot;}"/>
                                <td class="text-right Amiri">تاريخ الاستحقاق</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="col-xs-2">
                <img t-if="o.qr_code and o.zatca_onboarding_status != 1" t-att-src="'data:image/png;base64,%s' % o.qr_code" style="max-height: 180px;" />
                <img t-if="o.zatca_onboarding_status and o.zatca_hash_cleared_invoice" t-att-src="o.get_qrcode()" style="max-height: 180px;" alt="Barcode" />
                    
                </div>
            </div>
        </div>
        <div class="footer">
            <div class="row text-center footer-bg padding-top-8">
                <div class="col-xs-3">
                    <p>(س.ت:101075832)</p>
                </div>
                <div class="col-xs-3">
                    <p>+966-11-2006400 : فاكس</p>
                </div>
                <div class="col-xs-3">
                    <p>+966-11-2006066 : هاتف</p>
                </div>
                <div class="col-xs-3">
                    <p>المركز الرئيسي: ص.ب.19389 الرياض 11437</p>
                </div>
            </div>
            
            <div class="row Poppins">
                <div class="col-xs-12">
                    <p class="text-center">
                        <ul class="list-inline text-center">
                            <li>Page</li>
                            <li>
                                <span class="page"/>
                            </li>
                            <li>of</li>
                            <li>
                                <span class="topage"/>
                            </li>
                        </ul>
                    </p>
                </div>
            </div>
        </div>
    </t>
        </template>
        
