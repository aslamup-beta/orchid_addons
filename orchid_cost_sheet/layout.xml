                </div>
            </div>
            <div class="footer">
                <div class="row">
                    <div class="col-xs-6">
                        <a href="https://betait.net/" class="text-black">
                            <span class="fa fa-globe mr4"/>
                            <span>https://betait.net/</span>
                        </a>
                    </div>
                    <div class="col-xs-2 col-xs-offset-4 text-right">
                    </div>
                </div>
            </div>
        </template>

