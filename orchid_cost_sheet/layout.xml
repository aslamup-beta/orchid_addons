        <template id="layout" inherit_id="web.layout">
            <xpath expr="." positon="inside">
                <link rel="stylesheet" href='/orchid_cost_sheet/static/src/css/remove_sheet.css'/>
            </xpath>
        </template>
        <template id="minimal_layout_pdf" inherit_id="report.minimal_layout">
            <xpath expr="//head" position="inside">
                <link href="/orchid_cost_sheet/static/src/css/report_style.css" rel="stylesheet"/>
            </xpath>
            <xpath expr="//head" position="inside">
                <link href="/orchid_cost_sheet/static/src/css/report_style.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@200&amp;display=swap"
                      rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Amiri&amp;display=swap" rel="stylesheet"/>
            </xpath>
        </template>
        <template id="minimal_layout_html" inherit_id="report.external_layout">
