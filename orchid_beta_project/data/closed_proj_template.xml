    	<record id="od_closed_project_notify" model="email.template">
             <field name="name">UAE - Analytic/Project Closed Mail</field>
             <field name="email_from"><![CDATA[ERP Notification <erp@en.betait.net>]]></field>
             <field name="subject">Analytic/Project Closed: ${object.name}</field>
             <field name="email_to">${object.od_owner_id.email}</field>
             <field name="email_cc">${object.od_branch_id.email},${object.od_branch_id.pmo_manager_id.email},support@betait.net</field>
             <field name="model_id" ref="model_project_project"/>
             <field name="body_html"><![CDATA[
          
          
                <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
                    <p>Dear ,</p>
                    
                    <p style="text-align: justify;">The following project is closed :</p>
                    <ul>
                    <li>Project Reference: ${object.code}  </li>
                    <li>Project Name: ${object.name}</li>
                    <li>Project Manager: ${object.od_owner_id.name}</li>
                    <li>Branch: ${object.od_branch_id.name}</li>
                    <li>Customer: ${object.partner_id.name}</li><li>Project Sales Value: ${object.od_amended_sale_price}</li><li>Project Actual GP:&nbsp;&nbsp;${object.od_actual_profit}</li>
                    <li>link:&nbsp;https://erp.betait.net/web?#id=<span style="text-align: justify;">${object.id}</span>&amp;view_type=form&amp;model=project.project&amp;menu_id=308&amp;action=390</li></ul>
                    
                </div>            
            
             ]]>
             </field>
         </record>
         
