<?xml version="1.0" encoding="UTF-8"?>
<openerp>
	<data>

		<record model="ir.ui.view" id="engineer_certificate_form">
		<field name="name">engineer certificate form view</field>
		<field name="model">engineer.certificate</field>
		<field name="arch" type="xml">
		<form string="engineer Certificate Session" >
 			<header>
 			
<!--  			        <button name="btn_confirm" states="draft" string="Confirm" type="object" /> -->
<!--  			        <button name="btn_reset_draft" states="in_progress" string="Reset to Draft" type="object" /> -->
 			         <button name="btn_done" states="in_progress" string="Done" type="object" />
 			         <button name="btn_reset_progress" states="done" string="Reset to Progress" type="object" />
                    <field name="state" widget="statusbar" nolabel="1" />
                    
                </header>
 			<sheet>
 			
			<group>
			     <group>
			       <field name="name" required="1"/>
			       <field name="brand_id" required="1" />
			        <field name="certificate_id" required="1" />
			        <field name="company_id" invisible="1"/>
			     </group>
			     <group>
			         <field name="month" required="1" attrs="{'readonly':[('state','!=','draft')]}"/>
			         <!--  <field name="date" required="1"/> -->
			         <field name="user_id" required="1"/>
			         <field name="allow_same_mnth" invisible="1"/>
			         
			     </group>
			      
					
			</group>
			<notebook>
			  <page string="Attendees">
			    <field name="attendees_ids" attrs="{'readonly':[('state','!=','draft')]}">
			       <tree editable="bottom">
			         <field name="user_id" context="{'not_sam_ids':1}" required="1"/>
			          <field name="status" readonly="1"/>
			          <button name="btn_confirm"  string="Confirm" type="object" attrs="{'invisible':[('status','!=','waiting')]}" />
			       </tree>
			    </field>
			  </page>
			    <page string="Clear Certificate Attendees" attrs="{'invisible':[('state','=','draft')]}">
			      <div>
			      <p>
			      This action is used for assigning another Certificate, so this will remove Currently Assigned Certificate
			      </p>
			      </div>
			    <field name="clear_attendees_ids">
			       <tree editable="bottom">
			         <field name="user_id" context="{'not_sam_ids':1}" required="1"/>
			          <field name="status" readonly="1" />
			          <button name="btn_clear"  string="Clear" type="object" attrs="{'invisible':[('status','!=','draft')]}" />
			       </tree>
			    </field>
			  </page>
			</notebook>
			</sheet>
		</form>
		</field>
		</record>

		<record model="ir.ui.view" id="engineer_certificate_tree">
		<field name="name">engineer certificate tree view</field>
		<field name="model">engineer.certificate</field>
		<field name="arch" type="xml">
			<tree string="engineer Certificate ">
				
					  <field name="name" />
			          <field name="certificate_id" />
			          <field name="month" />
			          <field name="date" />
			          <field name="user_id" />
			</tree>
		</field>
		</record>

		<record model="ir.ui.view" id="engineer_certificate_search">
		<field name="name">engineer certificate search view</field>
		<field name="model">engineer.certificate</field>
		<field name="arch" type="xml">
			<search>
					  <field name="name" />
			        <field name="certificate_id" />
			         <field name="month" />
			          <field name="date" />
			          	<field name="user_id" />
					
			</search>
		</field>
		</record>


		<record model="ir.actions.act_window" id="action_engineer_certificate">
		<field name="name">Engineer Certificate</field>
		<field name="res_model">engineer.certificate</field>
		<field name="view_mode">tree,form</field>
		</record>

		<menuitem 
	  		id="menu_engineer_certificate" 
	  		parent="menu_cert"
            action="action_engineer_certificate" />

	</data>
</openerp>
