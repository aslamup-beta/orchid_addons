<?xml version="1.0" encoding="UTF-8" ?>
<openerp>
    <data>
        <record id="invoice_form_report" model="ir.ui.view">
            <field name="name">view.move.form.inherit</field>
            <field name="inherit_id" ref="account.invoice_form"/>
            <field name="model">account.invoice</field>
            <field type="xml" name="arch">
                <!--            <xpath expr="//button[@name='action_post']" position="after">-->
                <xpath expr="//button[@name='invoice_open']" position="after">
                    <field name="l10n_sa_invoice_type" invisible="1"/>
                    <button name="print_einv_standard" type="object" string="Print E-invoice Standard"
                            class="oe_highlight"
                            attrs="{'invisible':[ '|', ('state','not in',['open', 'paid']), ('l10n_sa_invoice_type','!=', 'Standard')]}"/>
                    <button name="print_einv_b2c" type="object" string="Print E-invoice Simplified" class="oe_highlight"
                            attrs="{'invisible':[ '|', ('state','not in',['open', 'paid']), ('l10n_sa_invoice_type','!=', 'Simplified')]}"/>
                    <!--                groups="tax_reports.group_e_invoice_b2c"/>-->
                </xpath>
                <xpath expr="//field[@name='date_invoice']" position="after">
                    <field name="l10n_sa_qr_code_str" invisible="1"/>
                    <field name="invoice_multi_currency_id" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</openerp>