<openerp>
    <data>
        <record id="od_account_tax_view_inherit" model="ir.ui.view">
            <field name="name">account.tax</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/group" position="after">
                    <group string="Zatca">
                        <field name="classified_tax_category" string="Tax Category"/>
                        <field name="tax_exemption_selection"
                               attrs="{'required':[('classified_tax_category','in', ['E', 'Z'])],
                                       'invisible':[('classified_tax_category','not in', ['E', 'Z', 'O'])]}"/>
                        <field name="tax_exemption_code" force_save="1" readonly="1"
                               attrs="{'invisible':[('classified_tax_category','not in', ['E', 'Z', 'O'])]}"/>
                        <field name="tax_exemption_text" invisible="0" force_save="1"
                               attrs="{'invisible':[('classified_tax_category','not in', ['E', 'Z', 'O'])],
                                       'readonly':[('classified_tax_category','not in', ['O'])],
                                       'required':[('classified_tax_category','in', ['O'])],}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</openerp>