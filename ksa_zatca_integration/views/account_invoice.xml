<openerp>
    <data>
        <record id="od_zatcha_view_invoice_tree" model="ir.ui.view">
            <field name="name">account.invoice.tree</field>
            <field name="model">account.invoice</field>
            <field name="inherit_id" ref="account.invoice_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="after">
                    <field name="l10n_sa_zatca_status" widget="badge"/>
                </field>
            </field>
        </record>

        <record id="od_zatcha_view_invoice_form" model="ir.ui.view">
            <field name="name">account.invoice.form</field>
            <field name="model">account.invoice</field>
            <field name="inherit_id" ref="account.invoice_form"/>
            <field name="arch" type="xml">
                <button name="%(account.action_account_invoice_refund)d" position="after">
                    <field name="zatca_compliance_invoices_api" invisible="1"/>
                    <field name="zatca_onboarding_status" invisible="1"/>
                    <field name="zatca_status_code" invisible="1"/>

                    <button name="send_for_compliance" type="object" string="Send to Zatca for Compliance"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|',('state','not in', ['open', 'paid','accept']), ('zatca_compliance_invoices_api','not in', [0, None, '', False]), ('zatca_onboarding_status','=', True)]}"/>
                    <button name="send_for_clearance" type="object" string="Send to Zatca for Clearance"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|', '|', ('state','not in', ['open', 'paid','accept']), ('l10n_sa_invoice_type','!=', 'Standard'), ('zatca_compliance_invoices_api','not in', [0, None, '', False]), ('zatca_onboarding_status','=', False)]}"/>
                    <button name="send_for_reporting" type="object" string="Send to Zatca for Reporting"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|', '|', ('state','not in', ['open', 'paid','accept']), ('l10n_sa_invoice_type','!=', 'Simplified'), ('zatca_compliance_invoices_api','not in', [0, None, '', False]), ('zatca_onboarding_status','=', False)]}"/>

                    <button name="send_for_compliance" type="object" string="ReSend to Zatca for Compliance"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|', ('state','not in', ['open', 'paid','accept']), ('zatca_onboarding_status','=', True), ('zatca_status_code','!=','400')]}"
                            context="{'xml_generate': 1}"/>
                    <button name="send_for_clearance" type="object" string="ReSend to Zatca for Clearance"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|', '|', ('state','not in', ['open', 'paid','accept']), ('zatca_onboarding_status','=', False), ('l10n_sa_invoice_type','!=', 'Standard'), ('zatca_status_code','!=','400')]}"
                            context="{'xml_generate': 1}"/>
                    <button name="send_for_reporting" type="object" string="ReSend to Zatca for Reporting"
                            class="oe_highlight"
                            attrs="{'invisible':['|', '|', '|', ('state','not in', ['open', 'paid','accept']), ('zatca_onboarding_status','=', False), ('l10n_sa_invoice_type','!=', 'Simplified'), ('zatca_status_code','!=','400')]}"
                            context="{'xml_generate': 1}"/>
                </button>
                <field name="date_invoice" position="after">
                    <field name="l10n_sa_show_delivery_date" invisible="1"/>
                    <field name="l10n_sa_delivery_date" invisible="1" attrs="{'required': [('l10n_sa_show_delivery_date', '=', True)]}"/>
                    <field name="date_invoicetime" invisible="1" nolabel="0"
                           attrs="{'invisible': [('type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt'))],
                                                                                           'readonly': [('state', '!=', 'draft')]}"/>
                </field>
<!--                 <xpath expr="//field[@name='date_invoice']" position="replace"> -->
<!--                     <field name="date_invoicetime" nolabel="0" -->
<!--                            attrs="{'invisible': [('type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt'))], -->
<!--                                                                                            'readonly': [('state', '!=', 'draft')]}"/> -->
<!--                     <field name="date_invoice" invisible="1"/> -->
<!--                 </xpath> -->
               
<!--                 <xpath expr="//notebook//field[@name='comment']" position="after"> -->
<!--                     <p>If no tax is selected then tax category 'O' is applied, with tax exemption text as "Not subject -->
<!--                         to VAT". -->
<!--                     </p> -->
<!--                     <p>but tax must be selected.</p> -->
<!--                 </xpath> -->
<!--                 <xpath expr="//notebook" position="before"> -->
                    <!--                <xpath expr="//group[@id='header_right_group']" position="after">-->
                    
                    <!--                    <group string="Zatca Testing Fields">-->
                    <!--                        <group>-->
                    <!--                            <field name="l10n_sa_invoice_type" required="1" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                            <field name="l10n_is_third_party_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                            <field name="l10n_is_nominal_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                        </group>-->
                    <!--                        <group>-->
                    <!--                            <field name="l10n_is_exports_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                            <field name="l10n_is_summary_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                            <field name="l10n_is_self_billed_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>-->
                    <!--                        </group>-->
                    <!--                    </group>-->
<!--                 </xpath> -->
                <xpath expr="//notebook" position="inside">
                    <page string="Zatca"
                           attrs="{'invisible': [('company_id', '!=', 6)]}">
                        <!--                        <field name="l10n_sa_qr_code_str"/>-->
                        <!--                        <hr style="border: 1px solid black;"/>-->
                        <!--                        <field name="sa_qr_code_str"/>-->
                        <!--                        <hr style="border: 1px solid black;"/>-->
                        <group string="Zatca Fields" >
                        <group>
                            <field name="l10n_sa_invoice_type"
                                   attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('company_id', '=', 6)]}"/>
                            <field name="l10n_is_third_party_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="l10n_is_exports_invoice" attrs="{'invisible':[('l10n_sa_invoice_type','=', 'Simplified')],
                                                                                  'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="zatca_onboarding_status"/>
                        </group>
                        <group>
                            <field name="l10n_is_nominal_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="l10n_is_summary_invoice" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="l10n_is_self_billed_invoice" attrs="{'invisible':['|', ('l10n_is_exports_invoice','=', True),
                                                                                                   ('l10n_sa_invoice_type','=', 'Simplified')],
                                                                                      'readonly': [('state', '!=', 'draft')]}"/>
                            
                    		<field name="l10n_payment_means_code" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </group>
                    </group>
                        <group col="2" attrs="{'invisible':[('zatca_invoice','=', False)]}" string="Zatca Response">
                            <field name="zatca_invoice" filename="zatca_invoice_name"
                                   attrs="{'invisible':[('zatca_invoice','=', False)]}"/>
                            <field name="zatca_invoice_name" invisible="1"/>
                            <!--                    <field name="zatca_hash_invoice" filename="zatca_hash_invoice_name"-->
                            <!--                           attrs="{'invisible':[('zatca_invoice','=', False)]}"/>-->
                            <!--                    <field name="zatca_hash_invoice_name" invisible="1"/>-->
                            <field name="zatca_hash_cleared_invoice_name" invisible="1"/>
                            <field name="zatca_hash_cleared_invoice" filename="zatca_hash_cleared_invoice_name"
                                   attrs="{'invisible':['|', ('zatca_hash_cleared_invoice','=', False), ('l10n_sa_invoice_type','=', 'Simplified')]}"/>
                        </group>
                        <hr style="border: 1px solid black;"/>
                        <field name="zatca_compliance_invoices_api"/>
                    </page>
                </xpath>
            </field>
        </record>
        
        <record id="zatca_response" model="ir.ui.view">
            <field name="name">account.invoice</field>
            <field name="model">account.invoice</field>
            <field name="priority" eval="1000"/>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="zatca_compliance_invoices_api"/>
                    </sheet>
                </form>
            </field>
        </record>
        
    </data>
</openerp>