<?xml version="1.0"?>
<openerp>
    <data>

        <record id="view_uae_salary_rpt" model="ir.ui.view">
            <field name="name">Uae Salary Sheet Report</field>
            <field name="model">uae.salary.sheet.wiz</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                    <group>
                        <field name="company_id" invisible="1"/>
                        <field name="period_id"/>
                        <field name="branch_ids" widget="many2many_tags"/>
                    </group>
                    <group></group>
                    <footer>
                        <button name="export_rpt" string="Export" type="object"/>
                        or
                        <button name="print_rpt" string="Print" type="object"/>
                        or
                        <button string="Cancel" special="cancel"/>
                        or
                        <button name="btn_export_excel" string="Export Excel" type="object" class="oe_highlight"/>

                        <field name="export_file" filename="export_name" readonly="1"/>
                    </footer>

                </form>
            </field>
        </record>
        <record id="action_salary_sheet_uae_rpt" model="ir.actions.act_window">
            <field name="name">Salary Sheet - UAE</field>
            <field name="res_model">uae.salary.sheet.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <menuitem

                id="od_menu_uae_salary_sheet_x1"
                parent="hr.menu_hr_reporting"
                sequence="10"
                action="action_salary_sheet_uae_rpt"/>

    </data>
</openerp>
			