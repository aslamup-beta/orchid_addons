<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data noupdate="0">
    
    	<record id="od_invoice_validated_email_template" model="email.template">
             <field name="name">UAE - Customer Invoice Validation Mail</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Invoice Validated: ${object.partner_id.name}</field>
             <field name="email_to">${object.od_analytic_account.od_owner_id.email}</field>
             <field name="model_id" ref="model_account_invoice"/>
             <field name="body_html"><![CDATA[
          
          
                <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
                    <p>Dear ,</p>
                    
                    <p style="text-align: justify;">Invoice related to below project is validated :</p>
                    <ul>
                    <li>Project Reference: ${object.od_analytic_account.code}  </li>
                    <li>Project Name: ${object.od_analytic_account.name}</li>
                    <li>Invoice Amount: ${object.amount_total}</li>
                    <li>link:&nbsp;https://erp.betait.net/web?#id=<span style="text-align: justify;">${object.id}</span>&amp;view_type=form&amp;model=account.invoice</li></ul>
                </div>            
            
             ]]>
             </field>
         </record>
         
         <record id="od_invoice_validated_email_template_saudi" model="email.template">
             <field name="name">KSA - Customer Invoice Validation Mail</field>
             <field name="email_from">${(user.email or '')|safe}</field>
             <field name="subject">Invoice Validated: ${object.partner_id.name}</field>
             <field name="email_to">${object.od_analytic_account.od_owner_id.email}</field>
             <field name="email_cc">${object.od_branch_id.pmo_manager_id.email}</field>
             <field name="model_id" ref="model_account_invoice"/>
             <field name="body_html"><![CDATA[
          
          
                 <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
                    <p>Dear ,</p>
                    
                    <p style="text-align: justify;">Invoice related to below project is validated :</p>
                    <ul>
                    <li>Project Reference: ${object.od_analytic_account.code}  </li>
                    <li>Project Name: ${object.od_analytic_account.name}</li>
                    <li>Invoice Amount: ${object.amount_total}</li>
                    <li>link:&nbsp;https://erp.betait.net/web?#id=<span style="text-align: justify;">${object.id}</span>&amp;view_type=form&amp;model=account.invoice</li></ul>
                </div>            
            
             ]]>
             </field>
         </record>
         
     </data>
</openerp>
