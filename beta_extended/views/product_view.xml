<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="product_template_common_form_inherit_renewal" model="ir.ui.view">
            <field name="name">product.template.common.form.inherit.renewal</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='active']" position="after">
                    <field name="is_renewal_required"/>
                </xpath>
            </field>
        </record>
    </data>
</openerp>
