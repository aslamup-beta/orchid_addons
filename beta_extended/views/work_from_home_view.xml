<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record model="ir.ui.view" id="wfh_form_view">
            <field name="name">Work From Home</field>
            <field name="model">hr.holidays.wfh</field>
            <field name="arch" type="xml">
                <form string="Work From Home">

                    <header>
                        <button string="Submit To Manager" type="object" name="action_submit" states="draft"
                                class="oe_highlight"/>
                        <button string="Approve" type="object" name="action_manager_approve" states="waiting_approval"
                                groups="orchid_beta.groups_beta_admin,__export__.res_groups_186,orchid_beta.group_beta_hr_officers,__export__.res_groups_227"
                                class="oe_highlight"/>
                        <button string="HR Approval" type="object" name="action_hr_approve" states="hr_approval"
                                groups="__export__.res_groups_245,__export__.res_groups_200" class="oe_highlight"/>
                        <button string="Refuse" type="object" name="action_refuse" states="waiting_approval,hr_approval"
                                groups="orchid_beta.groups_beta_admin,__export__.res_groups_186,orchid_beta.group_beta_hr_officers,__export__.res_groups_227"/>
                        <button string="Reset to Draft" name="action_reset" type="object"
                                groups="__export__.res_groups_245,__export__.res_groups_200"
                                attrs="{'invisible': [('state', 'not in', ['cancel'])]}"/>
                        <button string="Cancel" type="object" name="action_cancel" states="confirmed"
                                groups="__export__.res_groups_245,__export__.res_groups_200"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="can_reset" invisible="1"/>
                                <field name="employee_id" required="1"/>
                                <label for="number_of_days_temp" string="Duration"/>
                                <div>
                                    <group col="3">
                                        <field name="date_from" nolabel="1" required="1"
                                               on_change="onchange_date_from(date_to, date_from)"
                                               class="oe_inline"/>
                                        <label string="To" class="oe_inline"/>
                                        <field name="date_to" nolabel="1" required="1"
                                               on_change="onchange_date_to(date_to, date_from)"
                                               class="oe_inline"/>
                                    </group>
                                </div>
                                <label for="number_of_days_temp" string="Number Of Days" invisible="1"/>
                                <div invisible="1">
                                    <field name="number_of_days_temp" class="oe_inline" force_save="1"/>
                                    days
                                </div>
                                <label for="number_of_days" string="Number Of Days"/>
                                <div>
                                    <field name="number_of_days" class="oe_inline" force_save="1"/>
                                    days
                                </div>
                            </group>
                            <group>
                                <field name="wfh_type" readonly="1"/>

                                <field name="department_id"/>
                                <field name="manager_id"/>
                            </group>
                        </group>
                        <field name="name" nolabel="1" colspan="4" placeholder="Add a reason..." required="1"
                        />
                        <notebook>
                            <page string="Log Date History">
                                <group string="Log Date History">
                                    <field name="date_log_history_line" nolabel="1">
                                        <tree>
                                            <field name="name"/>
                                            <field name="user_id"/>
                                            <field name="date"/>
                                        </tree>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_holidays_wfh_tree">
            <field name="name">hr.holidays.wfh.tree</field>
            <field name="model">hr.holidays.wfh</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <tree colors="red:state == 'refuse';blue:state == ' draft';black:state in ('confirm','validate')"
                      string="Work From Home">
                    <field name="employee_id"/>
                    <field name="department_id" invisible="1"/>
                    <field name="wfh_type"/>
                    <field name="name"/>
                    <field name="number_of_days_temp" string="Number of Days"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="manager_id" invisible="1"/>
                    <field name="user_id" invisible="1"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_holidays_wfh_search_view">
            <field name="name">hr.holidays.wfh.search.view</field>
            <field name="model">hr.holidays.wfh</field>
            <field name="arch" type="xml">
                <search>
                    <field name="employee_id"/>
                    <field name="wfh_type"/>
                    <field name="state"/>
                    <group expand="1" string="Group By">
                        <filter string="Employee" domain="[]" context="{'group_by':'employee_id'}"/>
                        <filter string="Department" domain="[]" context="{'group_by':'department_id'}"/>
                        <filter string="Type" domain="[]" context="{'group_by':'wfh_type'}"/>
                        <filter string="State" domain="[]" context="{'group_by':'state'}"/>
<!--                        <filter string="Date From By Day" context="{'group_by':'date_from:day'}"/>-->
                        <filter string="Month" context="{'group_by': 'date_from:month'}"/>
                        <filter string="Year" context="{'group_by': 'date_from:year'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_open_wfh">
            <field name="name">Work From Home</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.holidays.wfh</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new request.
                </p>
            </field>
        </record>

        <menuitem name="Work From Home" action="action_open_wfh" parent="hr_holidays.menu_open_ask_holidays" groups="__export__.res_groups_184"
                  id="menu_open_wfh" sequence="90"/>

    </data>
</openerp>
