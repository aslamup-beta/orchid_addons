<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_od_beta_bank_loan_inherit" model="ir.ui.view">
            <field name="name">view.od.beta.bank.loan.inherit</field>
            <field name="model">od.beta.bank.loan</field>
            <field name="inherit_id" ref="beta_customisation.view_bank_loan_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string='Contract Details' invisible="1">
                        <group>
                            <group>
                                <field name="join_date"/>
                                <field name="allowance"/>
                            </group>
                            <group>
                                <field name="basic_salary"/>
                                <field name="total_salary"/>
                            </group>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//field[@name='n_bank_name']" position="after">
                    <field name="n_bank_name_ar"/>
                </xpath>
            </field>
        </record>
    </data>
</openerp>
