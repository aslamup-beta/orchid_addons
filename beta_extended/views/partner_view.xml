<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_partner_warning_form_inherit_opp" model="ir.ui.view">
            <field name="name">view.partner.warning.form.inherit.opp</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="warning.view_partner_warning_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@string='Warnings']" position="inside">
                    <group colspan="2" col="2">
                        <separator string="Warning on the Opportunity" colspan="4"/>
                        <field name="opp_warn" nolabel="1"/>
                        <field name="opp_warn_msg" colspan="3" nolabel="1"
                               attrs="{'required':[('opp_warn','!=','no-message')],'readonly':[('opp_warn','=','no-message')],'invisible':[('opp_warn','=','no-message')]}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</openerp>
