<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data>

        <record id="doc_refuse_wiz_form" model="ir.ui.view">
            <field name="name">doc.refuse.wiz.form</field>
            <field name="model">doc.refuse.wiz</field>
            <field name="arch" type="xml">
                <form string="Confirm">
                    <group>
                        <group>
                            <field name="refuse_reason" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Return" name="button_confirm" type="object" class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="doc_refuse_wiz_action" model="ir.actions.act_window">
            <field name="name">Return with Comments</field>
            <field name="res_model">doc.refuse.wiz</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</openerp>
