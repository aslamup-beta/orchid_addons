<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="account_invoice_form_inherit_actual_date" model="ir.ui.view">
            <field name="name">account.invoice.form.inherit.actual.date</field>
            <field name="model">account.invoice</field>
            <field name="inherit_id" ref="account.invoice_supplier_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_invoice']" position="after">
                    <field name="actual_inv_date" attrs="{'required':[('type','=','in_invoice')],'readonly':[('state','!=','draft')]}"/>
                </xpath>
            </field>
        </record>


         <record id="account_move_form_inherit_actual_date" model="ir.ui.view">
            <field name="name">account.move.form.inherit.actual.date</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date']" position="after">
                    <field name="actual_inv_date" attrs="{'readonly':[('state','!=','draft')]}"/>
                    <field name="sup_inv_number" attrs="{'readonly':[('state','!=','draft')]}"/>
                </xpath>
            </field>
        </record>


        <record id="account_move_form_voucher_inherit_actual_date" model="ir.ui.view">
            <field name="name">account.move.voucher.form.inherit.actual.date</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="orchid_acc_voucher.view_move_general_journal_orchid_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date']" position="after">
                    <field name="actual_inv_date" attrs="{'readonly':[('state','!=','draft')]}"/>
                    <field name="sup_inv_number" attrs="{'readonly':[('state','!=','draft')]}"/>
                </xpath>
            </field>
        </record>
    </data>
</openerp>
