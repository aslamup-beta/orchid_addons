            <field name="email_to">khalid.eqtifan@betait.net</field>
            <field name="email_cc">${object.manager_id.email}</field>
            <field name="model_id" ref="model_commitment_letter"/>
            <field name="body_html"><![CDATA[
	         <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
	             	<p>Dear Khalid Eqtifan,</p>
	             	<p>Kindly need your approval for the below Project Commitment Letter. Could you please review and approve at your earliest convenience?</p>
	             	<p>Info</p>
	                    <ul>
	                    	<li>S.No: ${object.name}</li>
	                    	<li>Project: ${object.project_id.name}</li>
	                        <li>Customer: ${object.customer_id.name}</li>
	                    	<li>link: https://erp.betait.net/web#id=${object.id}&view_type=form&model=commitment.letter&menu_id=1207&action=1913</li>
	                    </ul>    		
	         				              				    
	         		<p>Thank You</p>
	         </div>
             ]]>
            </field>
        </record>

