    	<record id="od_doc_request_approval_manager" model="email.template">
             <field name="name">UAE - Approve Document Request Manager</field>
             <field name="email_from"><![CDATA[ERP Notification <erp@en.betait.net>]]></field>
             <field name="subject">Approve Document Request - ${object.employee_id.name}</field>
             <field name="email_to">${object.manager_id.email}</field>
             <field name="email_cc">${object.employee_id.user_id.email}</field>
             <field name="model_id" ref="model_od_document_request"/>
             <field name="body_html"><![CDATA[
	         <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
	             	<p>Dear ${object.manager_id.name},</p>
	             	<p>Kindly need your Approval for the below document request.</p>
	             	<p>Info</p>
	                    <ul>
	                    	<li>Employee Name: ${object.employee_id.name}</li>
	                        <li>Document Type: ${object.document_type_id.name}</li>
                       		<li>Note: ${object.notes}</li>
	                    	<li>link: https://erp.betait.net/web#id=${object.id}&view_type=form&model=od.document.request&menu_id=697&action=915</li>
	                    </ul>         		
	         				              				    
	         		<p>Thank You</p>
	         </div>
             ]]>
             </field>
         </record>
    
